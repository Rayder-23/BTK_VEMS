@* Animated statistics band below hero (numbers counted in via site.js when visible) *@
<section id="stats" class="hero-stats-section py-4 py-lg-5" aria-labelledby="stats-heading">
    <div class="container">
        <h2 id="stats-heading" class="visually-hidden">Impact at a glance</h2>
        <div class="row g-4 g-lg-5 text-center justify-content-center">
            <div class="col-6 col-md-3">
                <div class="hero-stat-card h-100 p-3 p-lg-4 rounded-4 border-0 bg-white shadow-sm">
                    <div class="stat-icon-wrap mx-auto mb-2 mb-md-3" aria-hidden="true">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div class="hero-stat-number fw-bold text-primary mb-1" data-stat-target="10000" data-stat-suffix="+">0</div>
                    <div class="small text-muted text-uppercase fw-semibold letter-spacing-sm">Students</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="hero-stat-card h-100 p-3 p-lg-4 rounded-4 border-0 bg-white shadow-sm">
                    <div class="stat-icon-wrap mx-auto mb-2 mb-md-3" aria-hidden="true">
                        <i class="bi bi-person-badge-fill"></i>
                    </div>
                    <div class="hero-stat-number fw-bold text-primary mb-1" data-stat-target="500" data-stat-suffix="+">0</div>
                    <div class="small text-muted text-uppercase fw-semibold letter-spacing-sm">Teachers</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="hero-stat-card h-100 p-3 p-lg-4 rounded-4 border-0 bg-white shadow-sm">
                    <div class="stat-icon-wrap mx-auto mb-2 mb-md-3" aria-hidden="true">
                        <i class="bi bi-journal-richtext"></i>
                    </div>
                    <div class="hero-stat-number fw-bold text-primary mb-1" data-stat-target="100" data-stat-suffix="+">0</div>
                    <div class="small text-muted text-uppercase fw-semibold letter-spacing-sm">Online Courses</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="hero-stat-card hero-stat-card-text h-100 p-3 p-lg-4 rounded-4 border-0 bg-primary bg-gradient text-white shadow">
                    <div class="stat-icon-wrap stat-icon-light mx-auto mb-2 mb-md-3" aria-hidden="true">
                        <i class="bi bi-mortarboard-fill"></i>
                    </div>
                    <p class="hero-stat-label fw-bold mb-0 lh-sm">Class 1 to 12<br /><span class="fw-semibold opacity-90">Education</span></p>
                </div>
            </div>
        </div>
    </div>
</section>
