@* Sample course catalog with cards *@
<section id="courses" class="py-5 bg-light section-courses">
    <div class="container py-4">
        <div class="text-center mb-5">
            <h2 class="fw-bold section-title">Featured programs</h2>
            <p class="text-muted col-lg-7 mx-auto mb-0">
                Stackable credentials that pair theory with applied labs. Explore pathways aligned to industry demand curves.
            </p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-xl-3">
                <article class="card border-0 course-card rounded-4 overflow-hidden shadow-sm h-100">
                    <img src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=600&q=80" class="card-img-top course-thumb" alt="Code on a laptop display" loading="lazy" />
                    <div class="card-body d-flex flex-column p-4">
                        <h3 class="h5 fw-semibold mb-2">Web Development</h3>
                        <p class="text-muted small flex-grow-1">Full-stack foundations: HTML semantics, APIs, React components, and cloud deploys.</p>
                        <a href="#contact" class="btn btn-primary rounded-pill mt-2 align-self-start btn-course">Learn more</a>
                    </div>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="card border-0 course-card rounded-4 overflow-hidden shadow-sm h-100">
                    <img src="https://images.unsplash.com/photo-1677442136019-21780ecad995?w=600&q=80" class="card-img-top course-thumb" alt="Abstract visualization representing AI" loading="lazy" />
                    <div class="card-body d-flex flex-column p-4">
                        <h3 class="h5 fw-semibold mb-2">AI &amp; Machine Learning</h3>
                        <p class="text-muted small flex-grow-1">Model training, evaluation, responsible AI, and MLOps sprint formats.</p>
                        <a href="#contact" class="btn btn-primary rounded-pill mt-2 align-self-start btn-course">Learn more</a>
                    </div>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="card border-0 course-card rounded-4 overflow-hidden shadow-sm h-100">
                    <img src="https://images.unsplash.com/photo-1544383835-bda2bc66a55d?w=600&q=80" class="card-img-top course-thumb" alt="Database server hardware" loading="lazy" />
                    <div class="card-body d-flex flex-column p-4">
                        <h3 class="h5 fw-semibold mb-2">Database Management</h3>
                        <p class="text-muted small flex-grow-1">Relational design, performance tuning, replication, and secure access patterns.</p>
                        <a href="#contact" class="btn btn-primary rounded-pill mt-2 align-self-start btn-course">Learn more</a>
                    </div>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="card border-0 course-card rounded-4 overflow-hidden shadow-sm h-100">
                    <img src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=600&q=80" class="card-img-top course-thumb" alt="Earth from space representing cloud networks" loading="lazy" />
                    <div class="card-body d-flex flex-column p-4">
                        <h3 class="h5 fw-semibold mb-2">Cloud Computing</h3>
                        <p class="text-muted small flex-grow-1">Infrastructure as code, observability, autoscaling, and zero-trust networking.</p>
                        <a href="#contact" class="btn btn-primary rounded-pill mt-2 align-self-start btn-course">Learn more</a>
                    </div>
                </article>
            </div>
        </div>
