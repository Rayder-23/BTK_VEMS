@* Pakistan-focused hero carousel: bold typography, highlights, dual CTAs *@
<section id="home" class="hero-carousel carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="6000">
    <div class="carousel-indicators mb-4">
        <button type="button" data-bs-target="#home" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
        <button type="button" data-bs-target="#home" data-bs-slide-to="1" aria-label="Slide 2"></button>
        <button type="button" data-bs-target="#home" data-bs-slide-to="2" aria-label="Slide 3"></button>
    </div>
    <div class="carousel-inner">
        @* Slide 1 — primary message: Virtual Education in Pakistan *@
        <div class="carousel-item active">
            @* Classroom / school learning (high-quality education imagery) *@
            <div class="hero-slide" style="background-image: url('https://images.unsplash.com/photo-1580582932707-520657eec5e6?w=1920&q=88');"></div>
            <div class="carousel-caption hero-caption-centered text-center">
                <div class="container hero-caption-inner px-3">
                    <h1 class="hero-main-title text-white mb-3 mb-md-4">
                        <span class="hero-highlight">Virtual Education</span> in <span class="hero-highlight">Pakistan</span>
                    </h1>
                    <p class="hero-sub-title mb-3 mb-md-4">
                        Online Classes from <span class="hero-highlight">Class 1 to 12</span>
                    </p>
                    <p class="hero-description mx-auto mb-4 mb-lg-5">
                        Smart digital learning platform for students across Pakistan with interactive classes, qualified teachers,
                        online assessments, and modern education tools.
                    </p>
                    <div class="d-flex flex-column flex-sm-row gap-3 gap-sm-4 justify-content-center align-items-center hero-cta-row">
                        <a href="#courses" class="btn btn-primary btn-lg rounded-pill px-4 px-md-5 py-3 hero-cta shadow-lg">Explore Courses</a>
                        <a href="#admissions" class="btn btn-lg rounded-pill px-4 px-md-5 py-3 hero-cta-secondary text-primary fw-semibold shadow-lg">Student Registration</a>
                    </div>
                </div>
            </div>
        </div>
        @* Slide 2 — virtual classrooms *@
        <div class="carousel-item">
            <div class="hero-slide" style="background-image: url('https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=1920&q=88');"></div>
            <div class="carousel-caption hero-caption-centered text-center">
                <div class="container hero-caption-inner px-3">
                    <h2 class="hero-main-title hero-slide-alt-title text-white mb-3 mb-md-4">
                        Virtual Classrooms for <span class="hero-highlight">Pakistani Schools</span>
                    </h2>
                    <p class="hero-sub-title mb-3 mb-md-4">Study from home with structured timetables &amp; live support</p>
                    <p class="hero-description mx-auto mb-4 mb-lg-5">
                        Bring Matric, intermediate, and school-level learning online with secure access, recordings you can replay,
                        and teachers who understand Pakistan’s curriculum expectations.
                    </p>
                    <div class="d-flex flex-column flex-sm-row gap-3 gap-sm-4 justify-content-center align-items-center hero-cta-row">
                        <a href="#courses" class="btn btn-primary btn-lg rounded-pill px-4 px-md-5 py-3 hero-cta shadow-lg">Explore Courses</a>
                        <a href="#admissions" class="btn btn-lg rounded-pill px-4 px-md-5 py-3 hero-cta-secondary text-primary fw-semibold shadow-lg">Student Registration</a>
                    </div>
                </div>
            </div>
        </div>
        @* Slide 3 — online learning / youth *@
        <div class="carousel-item">
            <div class="hero-slide" style="background-image: url('https://images.unsplash.com/photo-1509062522246-3755977927d7?w=1920&q=88');"></div>
            <div class="carousel-caption hero-caption-centered text-center">
                <div class="container hero-caption-inner px-3">
                    <h2 class="hero-main-title hero-slide-alt-title text-white mb-3 mb-md-4">
                        Nation-wide <span class="hero-highlight">Digital Learning</span>
                    </h2>
                    <p class="hero-sub-title mb-3 mb-md-4">From primary foundations to exam readiness</p>
                    <p class="hero-description mx-auto mb-4 mb-lg-5">
                        Bridge urban and remote learners with one platform: revision banks, practice tests, parent visibility,
                        and pathways aligned to how students grow from <span class="hero-highlight">Class 1 to 12</span>.
                    </p>
                    <div class="d-flex flex-column flex-sm-row gap-3 gap-sm-4 justify-content-center align-items-center hero-cta-row">
                        <a href="#courses" class="btn btn-primary btn-lg rounded-pill px-4 px-md-5 py-3 hero-cta shadow-lg">Explore Courses</a>
                        <a href="#admissions" class="btn btn-lg rounded-pill px-4 px-md-5 py-3 hero-cta-secondary text-primary fw-semibold shadow-lg">Student Registration</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#home" data-bs-slide="prev">
        <span class="carousel-control-prev-icon rounded-circle hero-control shadow" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#home" data-bs-slide="next">
        <span class="carousel-control-next-icon rounded-circle hero-control shadow" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</section>
