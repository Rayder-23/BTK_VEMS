<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @{
        var layoutTitle = ViewData["Title"] as string ?? "Home";
        var siteName = "Virtual Education Management System";
    }
    <title>@layoutTitle — @siteName</title>

    @* Typography *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    @* Bootstrap 5 stylesheet (CDN per project specification) *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />

    @* Bootstrap Icons (CDN) *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    @* Site theme overrides — keep below frameworks *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="public-site d-flex flex-column min-vh-100">

    @* Slim utility bar above primary navigation *@
    <partial name="_PublicTopBar" />

    @* Sticky main navbar *@
    <partial name="_PublicNavbar" />

    @* Primary page region is full-width; inner sections decide container width *@
    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    @* Institutional footer mirrors top-of-page contact + social motifs *@
    <partial name="_PublicFooter" />

    @* jQuery omitted — not required by current views; uncomment if you add validations/widgets *@
    @* Bootstrap 5 bundle (CDN) includes Popper *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
