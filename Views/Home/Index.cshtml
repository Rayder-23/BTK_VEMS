@model HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
}

@if (!string.IsNullOrWhiteSpace(Model.ApplicationSuccessMessage))
{
    <div class="container mt-3">
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <strong>@Model.ApplicationSuccessMessage</strong>
            @if (!string.IsNullOrWhiteSpace(Model.ApplicationReferenceNo))
            {
                <span class="d-block mt-1">Reference number: <strong>@Model.ApplicationReferenceNo</strong></span>
            }
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
}

@* Modular home sections assembled from partial views for readability *@
<partial name="_HomeHeroCarousel" />
<partial name="_HomeStats" />
<partial name="_HomeFeatures" />
<partial name="_HomeAbout" />
@* Navbar anchors Admissions & Teachers resolve to these belts *@
<partial name="_HomeAdmissions" />
<partial name="_HomeTeachers" />
<partial name="_HomeCourses" />
