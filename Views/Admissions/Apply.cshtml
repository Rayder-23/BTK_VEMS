@model StudentApplicationPageViewModel
@{
    ViewData["Title"] = "Apply for admission";
    var form = Model.Form;
}

<section class="application-page-hero">
    <div class="container">
        <h1 class="application-page-title mb-1">Student application</h1>
        <p class="application-page-lead mb-0 col-lg-8">
            Complete the form below to apply for the upcoming admission cycle. Fields marked with
            <span class="text-danger">*</span> are required.
        </p>
    </div>
</section>

<section class="application-page-body">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12">
                @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
                {
                    <div class="alert alert-success shadow-sm mb-4" role="status">
                        <h2 class="h5 fw-bold mb-2">@Model.SuccessMessage</h2>
                        @if (!string.IsNullOrWhiteSpace(Model.ReferenceNo))
                        {
                            <p class="mb-2">Your reference number is <strong>@Model.ReferenceNo</strong>. Please save it for future correspondence.</p>
                        }
                        <a href="/" class="btn btn-sm btn-success rounded-pill">Back to home</a>
                        <a asp-action="Apply" class="btn btn-sm btn-outline-success rounded-pill ms-2">Submit another application</a>
                    </div>
                }
                else
                {
                    <div class="card application-form-card shadow-sm">
                        <div class="card-body p-3 p-md-4">
                            <form asp-action="Apply" method="post" id="studentApplicationForm">
                                @Html.AntiForgeryToken()
                                @if (!ViewData.ModelState.IsValid)
                                {
                                    <div asp-validation-summary="All" class="alert alert-danger mb-4" role="alert"></div>
                                }

                                <partial name="_StudentApplicationForm" model="Model" />

                                <div class="d-flex flex-wrap gap-2 mt-3 pt-3 border-top">
                                    <button type="submit" class="btn btn-primary rounded-pill px-4">Submit application</button>
                                    <a href="/#admissions" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                                </div>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/admissions.js" asp-append-version="true"></script>
}
