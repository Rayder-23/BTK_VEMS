@model IReadOnlyList<StudentCourseRegistrationListItem>
@{
    ViewData["Title"] = "Uni student course registrations";
    var search = ViewData["Search"] as string;
    var message = TempData["StatusMessage"] as string;
}

<div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center mb-3">
    <div>
        <h1 class="h4 fw-bold mb-1">Uni student course registrations</h1>
        <p class="text-muted mb-0">Manage <code>dbo.StudentCourseRegistrations</code> records.</p>
    </div>
    <a class="btn btn-primary rounded-pill px-4" asp-action="Create">
        <i class="bi bi-plus-lg me-2"></i>Add registration
    </a>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mb-3" role="alert">@message</div>
}

<section class="portal-card">
    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-md-9">
            <label class="form-label" for="search">Search</label>
            <input type="search" class="form-control" id="search" name="search" value="@search"
                   placeholder="Student, registration no., course, or section" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Student</th>
                    <th>Course section</th>
                    <th>Registration date</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="5" class="text-muted py-4 text-center">No student course registrations found.</td>
                </tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.Uid</td>
                    <td>
                        <div class="fw-semibold">@row.StudentName</div>
                        @if (!string.IsNullOrWhiteSpace(row.RegistrationNo))
                        {
                            <div class="small text-muted">@row.RegistrationNo</div>
                        }
                    </td>
                    <td>@row.CourseSectionDisplay</td>
                    <td>@row.RegistrationDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-outline-success btn-sm" asp-action="Edit" asp-route-id="@row.Uid">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <form asp-action="Delete" asp-route-id="@row.Uid" method="post" class="d-inline"
                              onsubmit="return confirm('Delete this registration permanently?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
