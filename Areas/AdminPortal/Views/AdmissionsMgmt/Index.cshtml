@model VEMS.Areas.AdminPortal.Models.Admissions.AdmissionsDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="h4 fw-bold mb-3">Dashboard</h1>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-xl">
        <div class="portal-stat-card accent-cyan h-100">
            <div class="small text-muted">Total applicants</div>
            <div class="h3 fw-bold mb-0">@Model.TotalApplications</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl">
        <div class="portal-stat-card accent-orange h-100">
            <div class="small text-muted">Pending</div>
            <div class="h3 fw-bold mb-0">@Model.PendingApplications</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl">
        <div class="portal-stat-card accent-green h-100">
            <div class="small text-muted">Approved</div>
            <div class="h3 fw-bold mb-0">@Model.ApprovedApplications</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl">
        <div class="portal-stat-card accent-indigo h-100">
            <div class="small text-muted">Paid</div>
            <div class="h3 fw-bold mb-0">@Model.PaidApplications</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-xl">
        <div class="portal-stat-card accent-teal h-100">
            <div class="small text-muted">Online channel</div>
            <div class="h3 fw-bold mb-0">@Model.OnlineApplications</div>
        </div>
    </div>
</div>

<section class="portal-card">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h2 class="h6 fw-bold mb-0">Recent applicants</h2>
        <a class="btn btn-sm btn-outline-primary rounded-pill" href="/adminportal/admissions/applications">View all</a>
    </div>
    <div class="table-responsive">
        <table class="table admin-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Application no.</th>
                    <th>Date</th>
                    <th>Name</th>
                    <th>Program</th>
                    <th>Status</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.RecentApplications.Count == 0)
            {
                <tr><td colspan="6" class="text-center text-muted py-3">No applications yet.</td></tr>
            }
            @foreach (var row in Model.RecentApplications)
            {
                <tr>
                    <td><code>@row.ApplicationNo</code></td>
                    <td>@row.ApplicationDate.ToString("yyyy-MM-dd")</td>
                    <td>@row.FullName</td>
                    <td>@row.ProgramName</td>
                    <td><span class="badge text-bg-secondary">@row.ApplicationStatus</span></td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" href="/adminportal/admissions/applications/edit/@row.Uid">Edit</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
