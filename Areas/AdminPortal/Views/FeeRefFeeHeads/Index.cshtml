@model IReadOnlyList<VEMS.Areas.AdminPortal.Models.Fee.FeeHeadListItem>
@using VEMS.Areas.AdminPortal.Models.Fee
@{
    ViewData["Title"] = "Fee Heads";
    var search = ViewData["Search"] as string;
    var showInactive = ViewData["ShowInactive"] as bool? ?? false;
}

<section class="portal-card page-summary-compact mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/fee">Fee</a></li>
            <li class="breadcrumb-item active">Fee Heads</li>
        </ol>
    </nav>
    <div class="page-summary-head">
        <div class="page-summary-title-block">
            <span class="page-summary-title">Fee Heads</span>
            <span class="page-summary-meta">Manage ref_FeeHeads</span>
        </div>
        <a class="btn btn-sm btn-primary rounded-pill flex-shrink-0" href="/adminportal/fee/fee-heads/create">
            <i class="bi bi-plus-lg me-1"></i>Add fee head
        </a>
    </div>
</section>

<partial name="_FeeAlerts" />

<section class="portal-card mt-3">
    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-md-6">
            <label class="form-label" for="search">Search</label>
            <input type="search" class="form-control" id="search" name="search" value="@search" placeholder="Name, code, category" />
        </div>
        <div class="col-md-3">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="showInactive" value="true" id="showInactive" @(showInactive ? "checked" : "") />
                <label class="form-check-label" for="showInactive">Show inactive</label>
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Mandatory</th>
                    <th>Active</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="6" class="text-center text-muted py-4">No fee heads found.</td></tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.HeadCode</td>
                    <td>@row.HeadName</td>
                    <td>@row.Category</td>
                    <td>@(row.IsMandatory ? "Yes" : "No")</td>
                    <td>@(row.IsActive ? "Yes" : "No")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-success" href="/adminportal/fee/fee-heads/edit/@row.Uid">Edit</a>
                        @if (row.IsActive)
                        {
                            <form method="post" action="/adminportal/fee/fee-heads/delete/@row.Uid" class="d-inline"
                                  onsubmit="return confirm('Deactivate this fee head?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Deactivate</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>

