@model VEMS.Areas.AdminPortal.Models.Fee.FeeHeadFormModel
@using VEMS.Areas.AdminPortal.Models.Fee

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<div class="row g-3">
    <div class="col-md-4">
        <label asp-for="HeadCode" class="form-label"></label>
        <input asp-for="HeadCode" class="form-control" />
        <span asp-validation-for="HeadCode" class="text-danger"></span>
    </div>
    <div class="col-md-8">
        <label asp-for="HeadName" class="form-label"></label>
        <input asp-for="HeadName" class="form-control" />
        <span asp-validation-for="HeadName" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Category" class="form-label"></label>
        <select asp-for="Category" class="form-select" asp-items="@(new SelectList(FeeConstants.FeeHeadCategories))"></select>
    </div>
    <div class="col-md-3">
        <div class="form-check mt-4">
            <input asp-for="IsMandatory" class="form-check-input" />
            <label asp-for="IsMandatory" class="form-check-label"></label>
        </div>
    </div>
    <div class="col-md-3">
        <div class="form-check mt-4">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label">Active</label>
        </div>
    </div>
    <div class="col-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
    </div>
</div>

