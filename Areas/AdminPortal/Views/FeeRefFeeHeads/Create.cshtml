@model VEMS.Areas.AdminPortal.Models.Fee.FeeHeadFormModel
@{
    ViewData["Title"] = "Add Fee Head";
}

<section class="module-page-header accent-red">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal/fee">Fee</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/fee/fee-heads">Fee Heads</a></li>
            <li class="breadcrumb-item active">Add</li>
        </ol>
    </nav>
    <h1 class="h3 fw-bold">Add fee head</h1>
</section>

<partial name="_FeeAlerts" />

<section class="portal-card mt-4">
    <form method="post" asp-action="Create">
        @Html.AntiForgeryToken()
        <partial name="_FeeHeadForm" />
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" href="/adminportal/fee/fee-heads">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
