@model VEMS.Areas.AdminPortal.Models.Admissions.ApplicationChallanGenerateFormModel
@{
    ViewData["Title"] = "Create Challan";
}

<section class="portal-card page-summary-compact mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/admissions">Admissions</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/admissions/applications">Applications</a></li>
            <li class="breadcrumb-item active" aria-current="page">Create Challan</li>
        </ol>
    </nav>
    <div class="page-summary-head">
        <div class="page-summary-title-block">
            <span class="page-summary-title">Create challan</span>
            <span class="page-summary-meta">Admission fee challan for applicant <code>@Model.ApplicationNo</code></span>
        </div>
    </div>
</section>

<partial name="_FeeAlerts" />

<section class="portal-card">
    @if (!Model.FeeStructureFound)
    {
        <div class="alert alert-warning mb-3">
            No admission fee structure found for <strong>@Model.ProgramName</strong> (year @Model.DesiredYear).
            Configure a fee structure with an Admission fee head (ADM) before generating a challan.
        </div>
    }

    <form method="post" action="/adminportal/admissions/applications/challan/@Model.ApplicationUid">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ApplicationUid" />
        <input type="hidden" asp-for="StructureId" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="ApplicationNo" class="form-label"></label>
                <input asp-for="ApplicationNo" class="form-control" readonly />
            </div>
            <div class="col-md-6">
                <label class="form-label">Applicant</label>
                <input class="form-control" value="@Model.ApplicantName" readonly />
            </div>
            <div class="col-md-6">
                <label class="form-label">Program</label>
                <input class="form-control" value="@Model.ProgramName" readonly />
            </div>
            <div class="col-md-6">
                <label class="form-label">Fee structure</label>
                <input class="form-control" value="@(string.IsNullOrWhiteSpace(Model.StructureLabel) ? "—" : Model.StructureLabel)" readonly />
            </div>
            <div class="col-md-4">
                <label asp-for="AdmissionFeeAmount" class="form-label"></label>
                <input asp-for="AdmissionFeeAmount" class="form-control" readonly />
            </div>
            <div class="col-md-4">
                <label asp-for="IssueDate" class="form-label"></label>
                <input asp-for="IssueDate" class="form-control" type="date" />
            </div>
            <div class="col-md-4">
                <label asp-for="DueDate" class="form-label"></label>
                <input asp-for="DueDate" class="form-control" type="date" />
                <span asp-validation-for="DueDate" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="DiscountAmount" class="form-label"></label>
                <input asp-for="DiscountAmount" class="form-control" type="number" step="0.01" min="0" />
            </div>
            <div class="col-12">
                <label asp-for="Remarks" class="form-label"></label>
                <textarea asp-for="Remarks" class="form-control" rows="2"></textarea>
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary" @(Model.FeeStructureFound ? null : "disabled")>Generate</button>
            <a class="btn btn-outline-secondary" href="/adminportal/admissions/applications">Cancel</a>
        </div>
    </form>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
