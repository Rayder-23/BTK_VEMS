@model VEMS.Areas.AdminPortal.Models.Admissions.StudentApplicationFormViewModel
@{
    ViewData["Title"] = "Add Application";
    ViewData["PageTitle"] = "Add application";
}

<partial name="_FeeAlerts" />

<section class="module-page-header accent-purple">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/admissions/applications">Applications</a></li>
            <li class="breadcrumb-item active" aria-current="page">Add</li>
        </ol>
    </nav>
    <h1 class="h3 fw-bold mb-0">Add application</h1>
    <p class="text-muted mb-0 mt-2">Create a new student application record.</p>
</section>

<section class="portal-card mt-4">
    <form method="post" asp-action="Create" id="studentApplicationAdminForm" novalidate>
        @Html.AntiForgeryToken()
        <partial name="_StudentApplicationAdminForm" model="Model" />
        <div class="d-flex flex-wrap gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" href="/adminportal/admissions/applications">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/portals/admissions-admin.js" asp-append-version="true"></script>
}
