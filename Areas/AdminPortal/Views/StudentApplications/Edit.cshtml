@model VEMS.Areas.AdminPortal.Models.Admissions.StudentApplicationFormViewModel
@{
    ViewData["Title"] = Model.IsReadOnly ? "View Application" : "Edit Application";
    ViewData["PageTitle"] = Model.IsReadOnly
        ? $"View · {Model.Form.ApplicationNo}"
        : $"Edit · {Model.Form.ApplicationNo}";
}

<partial name="_FeeAlerts" />

<section class="portal-card page-summary-compact mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/admissions/applications">Applications</a></li>
            <li class="breadcrumb-item active" aria-current="page">@(Model.IsReadOnly ? "View" : "Edit")</li>
        </ol>
    </nav>
    <div class="page-summary-head">
        <div class="page-summary-title-block">
            <span class="page-summary-title">@(Model.IsReadOnly ? "View application" : "Edit application")</span>
            <span class="page-summary-meta">
                @if (Model.IsReadOnly)
                {
                    <text>Application <strong>@Model.Form.ApplicationNo</strong> — converted to student</text>
                }
                else
                {
                    <text>Application <strong>@Model.Form.ApplicationNo</strong></text>
                }
            </span>
        </div>
        <a class="btn btn-sm btn-outline-secondary rounded-pill flex-shrink-0" href="/adminportal/admissions/applications">
            Back to applications
        </a>
    </div>
</section>

<section class="portal-card">
    @if (Model.IsReadOnly)
    {
        <div class="alert alert-secondary py-2 mb-3" role="status">
            This applicant was converted to a student. Details are shown in read-only mode.
        </div>

        <partial name="_StudentApplicationAdminFormReadOnly" model="Model" />

        <div class="d-flex flex-wrap gap-2 mt-4">
            @if (Model.Form.ConvertedStudentID.HasValue)
            {
                <a class="btn btn-outline-success"
                   href="/adminportal/students/students/edit/@Model.Form.ConvertedStudentID">
                    View student #@Model.Form.ConvertedStudentID
                </a>
            }
            <a class="btn btn-outline-secondary" href="/adminportal/admissions/applications">Back to applications</a>
        </div>
    }
    else
    {
        <form method="post" asp-action="Edit" asp-route-id="@Model.Form.Uid" id="studentApplicationAdminForm" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Form.Uid" />
            <partial name="_StudentApplicationAdminForm" model="Model" />
            <div class="d-flex flex-wrap gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Save changes</button>
                <button type="submit"
                        id="convertAsStudentBtn"
                        class="btn btn-success @(Model.ShowConvertAsStudentButton ? "" : "d-none")"
                        formaction="/adminportal/admissions/applications/convert-as-student/@Model.Form.Uid"
                        formmethod="post"
                        onclick="return confirm('Create a student record from this approved application and mark the application as Converted As Student?');">
                    Convert As Student
                </button>
                <a class="btn btn-outline-secondary" href="/adminportal/admissions/applications">Cancel</a>
            </div>
        </form>
    }
</section>

@section Scripts {
    @if (!Model.IsReadOnly)
    {
        <partial name="_ValidationScriptsPartial" />
        <script src="~/js/portals/admissions-admin.js" asp-append-version="true"></script>
    }
}
