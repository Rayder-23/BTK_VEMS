@model IReadOnlyList<VEMS.Areas.AdminPortal.Models.Admissions.StudentApplicationListItem>
@{
    ViewData["Title"] = "Applications";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var statusOptions = ViewData["StatusOptions"] as IReadOnlyList<string> ?? Array.Empty<string>();
}

<section class="portal-card page-summary-compact mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/admissions">Admissions</a></li>
            <li class="breadcrumb-item active" aria-current="page">All Applicants</li>
        </ol>
    </nav>
    <div class="page-summary-head">
        <div class="page-summary-title-block">
            <span class="page-summary-title">All Applicants</span>
            <span class="page-summary-meta">Student applications in <code>dbo.StudentApplications</code></span>
        </div>
        <a class="btn btn-sm btn-primary rounded-pill flex-shrink-0" href="/adminportal/admissions/applications/create">
            <i class="bi bi-plus-lg me-1"></i>Add applicant
        </a>
    </div>
</section>

<partial name="_FeeAlerts" />

<section class="portal-card">
    <form method="get" class="row g-2 align-items-end mb-2">
        <div class="col-md-5">
            <label class="form-label" for="search">Search</label>
            <input type="search" class="form-control form-control-sm" id="search" name="search" value="@search"
                   placeholder="Application no., name, mobile, program" />
        </div>
        <div class="col-md-4">
            <label class="form-label" for="status">Status</label>
            <select class="form-select form-select-sm" id="status" name="status">
                <option value="">All statuses</option>
                @foreach (var s in statusOptions)
                {
                    if (string.Equals(status, s, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@s" selected="selected">@s</option>
                    }
                    else
                    {
                        <option value="@s">@s</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-sm btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-sm admin-table admin-table-compact align-middle mb-0">
            <thead>
                <tr>
                    <th>Application no.</th>
                    <th>Date</th>
                    <th>Applicant</th>
                    <th>Program</th>
                    <th>Status</th>
                    <th>Mobile</th>
                    <th>Source</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="8" class="text-center text-muted py-4">No applications found.</td></tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td class="fw-semibold"><code>@row.ApplicationNo</code></td>
                    <td>@row.ApplicationDate.ToString("yyyy-MM-dd")</td>
                    <td>@row.FullName</td>
                    <td>@row.ProgramName</td>
                    <td><span class="badge text-bg-secondary">@row.ApplicationStatus</span></td>
                    <td>@row.MobileNo</td>
                    <td>@row.SourceChannel</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-sm btn-outline-success" href="/adminportal/admissions/applications/challan/@row.Uid">Create Challan</a>
                        <a class="btn btn-sm btn-outline-primary" href="/adminportal/admissions/applications/edit/@row.Uid">Edit</a>
                        <form method="post" action="/adminportal/admissions/applications/delete/@row.Uid" class="d-inline"
                              onsubmit="return confirm('Delete this application permanently?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
