@model ConfigurationFormModel
@{
    ViewData["Title"] = "Add configuration";
}

<section class="module-page-header accent-purple">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/settings">Settings</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Configurations</a></li>
            <li class="breadcrumb-item active" aria-current="page">Add</li>
        </ol>
    </nav>
    <h1 class="h3 fw-bold mb-0">Add configuration</h1>
    <p class="text-muted mb-0 mt-2">New row in <code>dbo.Configurations</code>.</p>
</section>

<section class="portal-card mt-4">
    <form asp-action="Create" method="post" novalidate>
        @Html.AntiForgeryToken()
        <partial name="_ConfigurationForm" model="Model" />
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
}
