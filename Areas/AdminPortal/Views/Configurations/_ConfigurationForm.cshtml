@model ConfigurationFormModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row g-3">
    <div class="col-12 col-lg-6">
        <label asp-for="ConfigKey" class="form-label"></label>
        <input asp-for="ConfigKey" class="form-control" autocomplete="off" />
        <span asp-validation-for="ConfigKey" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-6 d-flex align-items-end">
        <div class="form-check form-switch mb-2">
            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
            <label asp-for="IsActive" class="form-check-label"></label>
        </div>
    </div>
    <div class="col-12">
        <label asp-for="ConfigValues" class="form-label"></label>
        <textarea asp-for="ConfigValues" class="form-control font-monospace" rows="6"></textarea>
        <span asp-validation-for="ConfigValues" class="text-danger small"></span>
    </div>
    <div class="col-12">
        <label asp-for="Description" class="form-label"></label>
        <input asp-for="Description" class="form-control" />
        <span asp-validation-for="Description" class="text-danger small"></span>
    </div>
    @if (Model.Uid > 0)
    {
        <div class="col-12 col-lg-6">
            <label asp-for="CreatedAt" class="form-label"></label>
            <input class="form-control" value="@(Model.CreatedAt?.ToString("yyyy-MM-dd HH:mm:ss") + " UTC")" readonly />
        </div>
        <div class="col-12 col-lg-6">
            <label asp-for="UpdatedAt" class="form-label"></label>
            <input class="form-control" value="@(Model.UpdatedAt?.ToString("yyyy-MM-dd HH:mm:ss") + " UTC")" readonly />
            <div class="form-text">Saved updates refresh <strong>UpdatedAt</strong> automatically.</div>
        </div>
    }
</div>
