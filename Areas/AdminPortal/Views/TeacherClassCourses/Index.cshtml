@model IReadOnlyList<TeacherClassCourseListItem>
@{
    ViewData["Title"] = "Teacher class courses";
    var search = ViewData["Search"] as string;
    var showInactive = ViewData["ShowInactive"] as bool? ?? false;
    var message = TempData["StatusMessage"] as string;
}

<section class="portal-card page-summary-compact mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/teachers">Teachers</a></li>
            <li class="breadcrumb-item active" aria-current="page">Teacher-Class-Course</li>
        </ol>
    </nav>
    <div class="page-summary-head">
        <div class="page-summary-title-block">
            <span class="page-summary-title">Teacher-Class-Course</span>
            <span class="page-summary-meta">Links in <code>dbo.TeacherClassCourses</code></span>
        </div>
        <a class="btn btn-sm btn-primary rounded-pill flex-shrink-0" asp-action="Create">
            <i class="bi bi-plus-lg me-1"></i>Link teacher
        </a>
    </div>
</section>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mb-3" role="alert">@message</div>
}

<section class="portal-card">
    <form method="get" class="row g-2 align-items-end mb-3" asp-action="Index">
        <div class="col-md-6">
            <label class="form-label" for="search">Search</label>
            <input type="search" class="form-control" id="search" name="search" value="@search"
                   placeholder="Teacher, class, course, role" />
        </div>
        <div class="col-md-3">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="showInactive" value="true" id="showInactive"
                       @(showInactive ? "checked" : "") />
                <label class="form-check-label" for="showInactive">Show inactive</label>
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-sm admin-table admin-table-compact align-middle mb-0">
            <thead>
                <tr>
                    <th>Teacher</th>
                    <th>Class</th>
                    <th>Course</th>
                    <th>Role</th>
                    <th>Active</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="7" class="text-center text-muted py-4">No teacher class course links found.</td></tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@row.TeacherName</div>
                        <div class="small text-muted">@row.EmployeeCode</div>
                    </td>
                    <td>@(string.IsNullOrWhiteSpace(row.ClassName) ? row.ClassCode : row.ClassName)</td>
                    <td>
                        <div class="fw-semibold">@row.CourseCode</div>
                        <div class="small text-muted">@row.CourseName</div>
                    </td>
                    <td>@row.Role</td>
                    <td>@(row.IsActive ? "Yes" : "No")</td>
                    <td>@row.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@row.Uid">Edit</a>
                        @if (row.IsActive)
                        {
                            <form method="post" asp-action="Delete" asp-route-id="@row.Uid" class="d-inline"
                                  onsubmit="return confirm('Deactivate this teacher class course link?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Deactivate</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
