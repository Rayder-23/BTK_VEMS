@model IReadOnlyList<VEMS.Areas.AdminPortal.Models.CourseListItem>
@{
    var search = ViewData["Search"] as string;
    var showInactive = ViewData["ShowInactive"] as bool? ?? false;
    var message = TempData["StatusMessage"] as string;
}

<section class="portal-card page-summary-compact mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/students">Student Management</a></li>
            <li class="breadcrumb-item active">Courses</li>
        </ol>
    </nav>
    <div class="page-summary-head">
        <div class="page-summary-title-block">
            <span class="page-summary-title">Courses</span>
            <span class="page-summary-meta">Manage dbo.Courses</span>
        </div>
        <a class="btn btn-sm btn-primary rounded-pill flex-shrink-0" href="/adminportal/students/courses/create">
            <i class="bi bi-plus-lg me-1"></i>Add course
        </a>
    </div>
</section>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mb-3" role="alert">@message</div>
}

<section class="portal-card">
    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-md-6">
            <label class="form-label" for="search">Search</label>
            <input type="search" class="form-control" id="search" name="search" value="@search" placeholder="Code, title, program" />
        </div>
        <div class="col-md-3">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="showInactive" value="true" id="showInactive" @(showInactive ? "checked" : "") />
                <label class="form-check-label" for="showInactive">Show inactive</label>
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-sm admin-table admin-table-compact align-middle mb-0">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Title</th>
                    <th>Program</th>
                    <th>Credits</th>
                    <th>Semester</th>
                    <th>Mandatory</th>
                    <th>Active</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="9" class="text-center text-muted py-3">No courses found.</td></tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.CourseCode</td>
                    <td>@row.CourseTitle</td>
                    <td>@row.ProgramName</td>
                    <td>@row.CreditHours</td>
                    <td>@(row.SemesterNo?.ToString() ?? "—")</td>
                    <td>@(row.IsMandatory ? "Yes" : "No")</td>
                    <td>@(row.IsActive ? "Yes" : "No")</td>
                    <td>@row.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-success" href="/adminportal/students/courses/edit/@row.Uid">Edit</a>
                        @if (row.IsActive)
                        {
                            <form method="post" action="/adminportal/students/courses/delete/@row.Uid" class="d-inline"
                                  onsubmit="return confirm('Deactivate this course?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Deactivate</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
