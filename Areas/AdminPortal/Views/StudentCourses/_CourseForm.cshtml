@model VEMS.Areas.AdminPortal.Models.CourseFormModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<input type="hidden" asp-for="CourseId" />

<div class="student-mgmt-admin-form-grid">
    <div class="row student-mgmt-admin-form-row g-1 align-items-center">
        <label class="col-6 col-lg-3 student-mgmt-admin-form-label" asp-for="CourseCode"></label>
        <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
            <input asp-for="CourseCode" class="form-control form-control-sm" maxlength="20" />
            <span asp-validation-for="CourseCode" class="text-danger small"></span>
        </div>
        <label class="col-6 col-lg-3 student-mgmt-admin-form-label" asp-for="CourseName"></label>
        <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
            <input asp-for="CourseName" class="form-control form-control-sm" maxlength="200" />
            <span asp-validation-for="CourseName" class="text-danger small"></span>
        </div>
    </div>
    <div class="row student-mgmt-admin-form-row g-1 align-items-center">
        <label class="col-6 col-lg-3 student-mgmt-admin-form-label" asp-for="CreditHours"></label>
        <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
            <input asp-for="CreditHours" class="form-control form-control-sm" type="number" min="0" />
            <span asp-validation-for="CreditHours" class="text-danger small"></span>
        </div>
        <label class="col-6 col-lg-3 student-mgmt-admin-form-label" asp-for="IsActive"></label>
        <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
            <div class="form-check mb-0">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>
        </div>
    </div>
</div>
