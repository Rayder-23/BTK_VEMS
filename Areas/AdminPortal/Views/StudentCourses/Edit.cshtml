@model VEMS.Areas.AdminPortal.Models.CourseFormPageViewModel
@{
    ViewData["Title"] = "Edit Course";
}

<section class="portal-card page-summary-compact mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/adminportal/students">Student Management</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/students/courses">Courses</a></li>
            <li class="breadcrumb-item active">Edit</li>
        </ol>
    </nav>
    <div class="page-summary-head">
        <div class="page-summary-title-block">
            <span class="page-summary-title">Edit course</span>
            <span class="page-summary-meta">@Model.Form.CourseCode — @Model.Form.CourseTitle</span>
        </div>
    </div>
</section>

<section class="portal-card">
    <form method="post" asp-action="Edit" asp-route-id="@Model.Form.Uid">
        @Html.AntiForgeryToken()
        <partial name="_CourseForm" model="Model" />
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" href="/adminportal/students/courses">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
