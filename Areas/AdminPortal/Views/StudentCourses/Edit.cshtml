@model VEMS.Areas.AdminPortal.Models.CourseFormModel
@{
    ViewData["Title"] = "Edit course";
}

<section class="module-page-header accent-indigo">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/settings">Settings</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Courses</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit</li>
        </ol>
    </nav>
    <h1 class="h3 fw-bold mb-0">Edit course</h1>
    <p class="text-muted mb-0 mt-2">Update <strong>@Model.CourseName</strong>.</p>
</section>

<section class="portal-card mt-4">
    <form asp-action="Edit" asp-route-id="@Model.CourseId" method="post" novalidate>
        @Html.AntiForgeryToken()
        <partial name="_CourseForm" model="Model" />
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
}
