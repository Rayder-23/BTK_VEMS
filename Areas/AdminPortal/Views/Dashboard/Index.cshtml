@model AdminDashboardViewModel

@{
    Layout = "/Areas/AdminPortal/Views/Shared/_AdminHomeLayout.cshtml";
    ViewData["Title"] = "Admin Dashboard";
    var adminUsername = Context.Session.GetString("AdminUsername") ?? "Admin";
    var moduleCount = Model.Modules.Count;
    var activeModuleCount = Model.Modules.Count(m => m.IsAvailable);
}

<div class="erp-dashboard">
    <nav aria-label="breadcrumb" class="erp-breadcrumb-wrap mb-3">
        <ol class="breadcrumb erp-breadcrumb mb-0">
            <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
        </ol>
    </nav>

    <header class="erp-dashboard-hero rounded-4 mb-4">
        <div class="row align-items-center g-4">
            <div class="col-lg-8">
                <p class="erp-dashboard-hero__eyebrow mb-2">
                    <i class="bi bi-speedometer2 me-2" aria-hidden="true"></i>
                    Administration Console
                </p>
                <h1 class="erp-dashboard-hero__title mb-2">Welcome back, @adminUsername</h1>
                <p class="erp-dashboard-hero__subtitle mb-0">
                    Access @activeModuleCount active modules across your student management ecosystem.
                    <span class="d-none d-md-inline">Use search to quickly find any module.</span>
                </p>
            </div>
            <div class="col-lg-4">
                <div class="erp-dashboard-hero__meta">
                    <div>
                        <span class="erp-dashboard-hero__meta-label">Today</span>
                        <strong id="dashboardDate">@DateTime.Now.ToString("dddd, MMM dd, yyyy")</strong>
                    </div>
                    <div class="erp-dashboard-hero__stat-pill">
                        <i class="bi bi-grid-3x3-gap-fill" aria-hidden="true"></i>
                        <span>@moduleCount modules</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <section class="erp-stats-section mb-4" aria-label="Key statistics">
        <div class="row g-3 g-lg-4">
            @foreach (var stat in Model.Statistics)
            {
                <div class="col-12 col-sm-6 col-xl-3">
                    <article class="erp-stat-card @stat.AccentClass h-100">
                        <div class="erp-stat-card__icon" aria-hidden="true">
                            <i class="bi @stat.IconClass" aria-hidden="true"></i>
                        </div>
                        <div class="erp-stat-card__content">
                            <p class="erp-stat-card__label mb-1">@stat.Title</p>
                            <p class="erp-stat-card__value mb-0">@stat.Value</p>
                        </div>
                    </article>
                </div>
            }
        </div>
    </section>

    <section class="erp-modules-section portal-card" aria-label="Application modules">
        <div class="erp-modules-section__header">
            <div>
                <h2 class="erp-modules-section__title mb-1">Modules</h2>
                <p class="erp-modules-section__subtitle mb-0">Launch academic, finance, HR, and operations workflows.</p>
            </div>
            <div class="erp-module-search-wrap">
                <i class="bi bi-search" aria-hidden="true"></i>
                <input class="form-control"
                       id="moduleSearchInput"
                       type="search"
                       placeholder="Search modules..."
                       aria-label="Search modules"
                       autocomplete="off" />
            </div>
        </div>

        <div class="row g-3 g-lg-4 erp-module-grid" id="moduleGrid">
            @foreach (var module in Model.Modules)
            {
                <partial name="_DashboardModuleCard" model="module" />
            }
        </div>

        <div class="erp-module-empty d-none" id="moduleEmptyState" role="status">
            <i class="bi bi-search" aria-hidden="true"></i>
            <p class="mb-0 fw-semibold">No modules found</p>
            <p class="mb-0 small text-muted">Try a different search term.</p>
        </div>
    </section>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/portals/admin-dashboard.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        (function () {
            const moduleSearchInput = document.getElementById('moduleSearchInput');
            const moduleItems = Array.from(document.querySelectorAll('.module-grid-item'));
            const moduleEmptyState = document.getElementById('moduleEmptyState');

            function filterModules() {
                const query = (moduleSearchInput?.value ?? '').trim().toLowerCase();
                let visibleCount = 0;

                moduleItems.forEach((item) => {
                    const searchableText = `${item.dataset.moduleName} ${item.dataset.moduleDescription}`.toLowerCase();
                    const isVisible = !query || searchableText.includes(query);
                    item.classList.toggle('d-none', !isVisible);
                    if (isVisible) {
                        visibleCount += 1;
                    }
                });

                moduleEmptyState?.classList.toggle('d-none', visibleCount > 0);
            }

            moduleSearchInput?.addEventListener('input', filterModules);

            document.querySelectorAll('[data-soon-module="true"]').forEach((card) => {
                card.addEventListener('click', (event) => {
                    event.preventDefault();
                    card.classList.add('erp-module-card--pulse');
                    window.setTimeout(() => card.classList.remove('erp-module-card--pulse'), 450);
                });
            });

            moduleItems.forEach((item, index) => {
                item.style.setProperty('--card-delay', `${index * 35}ms`);
            });
        })();
    </script>
}
