@model AdminDashboardViewModel

@{
    Layout = "/Areas/AdminPortal/Views/Shared/_AdminHomeLayout.cshtml";
    ViewData["Title"] = "Admin Portal";
    var moduleCount = Model.Modules.Count;
}

<header class="erp-dashboard-hero erp-dashboard-hero--fullwidth">
    <div class="erp-dashboard-hero__inner">
        <div class="row align-items-center g-3">
            <div class="col-lg-8">
                <h1 class="erp-dashboard-hero__title mb-0">Admin Portal</h1>
            </div>
            <div class="col-lg-4">
                <div class="erp-dashboard-hero__meta">
                    <div>
                        <span class="erp-dashboard-hero__meta-label">Today</span>
                        <strong id="dashboardDate">@DateTime.Now.ToString("dddd, MMM dd, yyyy")</strong>
                    </div>
                    <div class="erp-dashboard-hero__stat-pill">
                        <i class="bi bi-grid-3x3-gap-fill" aria-hidden="true"></i>
                        <span>@moduleCount modules</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>

<div class="admin-home-content erp-dashboard">
    <section class="erp-modules-section" aria-label="Application modules">
        <div class="erp-modules-section__toolbar mb-3">
            <div class="erp-module-search-wrap">
                <i class="bi bi-search" aria-hidden="true"></i>
                <input class="form-control"
                       id="moduleSearchInput"
                       type="search"
                       placeholder="Search modules..."
                       aria-label="Search modules"
                       autocomplete="off" />
            </div>
        </div>

        <div class="erp-module-grid" id="moduleGrid">
            @foreach (var module in Model.Modules)
            {
                <partial name="_DashboardModuleCard" model="module" />
            }
        </div>

        <div class="erp-module-empty d-none" id="moduleEmptyState" role="status">
            <i class="bi bi-search" aria-hidden="true"></i>
            <p class="mb-0 fw-semibold">No modules found</p>
            <p class="mb-0 small text-muted">Try a different search term.</p>
        </div>
    </section>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/portals/admin-dashboard.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        (function () {
            const moduleSearchInput = document.getElementById('moduleSearchInput');
            const moduleItems = Array.from(document.querySelectorAll('.module-grid-item'));
            const moduleEmptyState = document.getElementById('moduleEmptyState');

            function filterModules() {
                const query = (moduleSearchInput?.value ?? '').trim().toLowerCase();
                let visibleCount = 0;

                moduleItems.forEach((item) => {
                    const searchableText = `${item.dataset.moduleName} ${item.dataset.moduleDescription}`.toLowerCase();
                    const isVisible = !query || searchableText.includes(query);
                    item.classList.toggle('d-none', !isVisible);
                    if (isVisible) {
                        visibleCount += 1;
                    }
                });

                moduleEmptyState?.classList.toggle('d-none', visibleCount > 0);
            }

            moduleSearchInput?.addEventListener('input', filterModules);

            document.querySelectorAll('[data-soon-module="true"]').forEach((card) => {
                card.addEventListener('click', (event) => {
                    event.preventDefault();
                    card.classList.add('erp-module-card--pulse');
                    window.setTimeout(() => card.classList.remove('erp-module-card--pulse'), 450);
                });
            });

            moduleItems.forEach((item, index) => {
                item.style.setProperty('--card-delay', `${index * 35}ms`);
            });
        })();
    </script>
}
