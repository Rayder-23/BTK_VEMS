@model VEMS.Areas.AdminPortal.Models.Fee.PaymentFormModel
@using VEMS.Areas.AdminPortal.Models.Fee
@{
    ViewData["Title"] = "Record Payment";
    var challans = ViewData["Challans"] as IReadOnlyList<VEMS.Areas.AdminPortal.Models.Fee.FeeLookupItem> ?? [];
}

<section class="module-page-header accent-green">
    <h1 class="h3 fw-bold">Record payment</h1>
</section>

<partial name="_FeeAlerts" />

<section class="portal-card mt-4">
    <form method="post" id="paymentForm">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-md-8">
                <label asp-for="ChallanId" class="form-label"></label>
                <select asp-for="ChallanId" class="form-select" id="challanSelect"
                        asp-items="@(new SelectList(challans, "Id", "Name"))">
                    <option value="">— Select challan —</option>
                </select>
                <span asp-validation-for="ChallanId" class="text-danger"></span>
            </div>
            @if (!string.IsNullOrEmpty(Model.ChallanNo))
            {
                <div class="col-12">
                    <div class="alert alert-light border">
                        <strong>@Model.ChallanNo</strong> — @Model.StudentName<br />
                        Net: @Model.NetPayable.ToString("N2") · Paid: @Model.AmountPaidSoFar.ToString("N2") ·
                        Balance: <strong>@Model.Balance.ToString("N2")</strong>
                    </div>
                </div>
            }
            <div class="col-md-4">
                <label asp-for="AmountPaid" class="form-label"></label>
                <input asp-for="AmountPaid" class="form-control" type="number" step="0.01" min="0.01" />
                <span asp-validation-for="AmountPaid" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="PaymentDate" class="form-label"></label>
                <input asp-for="PaymentDate" class="form-control" type="date" />
            </div>
            <div class="col-md-4">
                <label asp-for="PaymentMode" class="form-label"></label>
                <select asp-for="PaymentMode" class="form-select" asp-items="@(new SelectList(FeeConstants.PaymentModes))"></select>
            </div>
            <div class="col-md-6">
                <label asp-for="TransactionRef" class="form-label"></label>
                <input asp-for="TransactionRef" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="BankName" class="form-label"></label>
                <input asp-for="BankName" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="ChequeNo" class="form-label"></label>
                <input asp-for="ChequeNo" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="Remarks" class="form-label"></label>
                <input asp-for="Remarks" class="form-control" />
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save payment</button>
            <a class="btn btn-outline-secondary" href="/adminportal/fee/payments">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('challanSelect')?.addEventListener('change', function () {
            if (this.value) window.location = '/adminportal/fee/payments/create?challanId=' + this.value;
        });
    </script>
}
