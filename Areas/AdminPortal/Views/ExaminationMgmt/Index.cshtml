@model IReadOnlyList<VEMS.Areas.AdminPortal.Models.Examination.ExaminationDashboardTile>
@{
    ViewData["Title"] = "Dashboard";
    ViewData["PageTitle"] = "Examination · Dashboard";
}

<h1 class="h4 fw-bold mb-3">Dashboard</h1>

<p class="text-muted mb-4">Exam setup, marking, schedules, student marks, submissions, grades, and semester results.</p>

<section class="portal-card" aria-label="Examination modules">
    <h2 class="h6 fw-bold mb-3">Modules</h2>
    <div class="row g-3 fm-module-grid">
        @foreach (var tile in Model)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <a class="fm-module-card @tile.AccentClass" href="@tile.Url">
                    <span class="fm-module-card__icon @tile.AccentClass">
                        <i class="bi @tile.IconClass"></i>
                    </span>
                    <h3 class="fm-module-card__title">@tile.Title</h3>
                    <p class="fm-module-card__desc">@tile.Description</p>
                </a>
            </div>
        }
    </div>
</section>
