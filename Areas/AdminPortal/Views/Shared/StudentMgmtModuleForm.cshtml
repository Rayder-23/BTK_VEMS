@model StudentMgmtFormPlaceholderViewModel
@{
    var title = Model.IsEdit ? $"Edit {Model.ModuleName}" : $"Add {Model.ModuleName}";
}

<section class="module-page-header @Model.AccentClass">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/students">HR</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/students/@Model.Segment">@Model.ModuleName</a></li>
            <li class="breadcrumb-item active" aria-current="page">@(Model.IsEdit ? "Edit" : "Add")</li>
        </ol>
    </nav>
    <h1 class="h3 fw-bold mb-0">@title</h1>
    <p class="text-muted mb-0 mt-2">@Model.Description</p>
</section>

<div class="sm-notice mt-4" role="status">
    <i class="bi bi-database-slash me-2"></i>
    This form is a placeholder. Saving will not persist data until the @Model.ModuleName database tables are created.
</div>

<section class="portal-card mt-4">
    <form method="post" action="@(Model.IsEdit ? $"/adminportal/students/{Model.Segment}/edit/{Model.Id}" : $"/adminportal/students/{Model.Segment}/create")">
        @Html.AntiForgeryToken()
        <div class="student-mgmt-admin-form-grid">
            <div class="row student-mgmt-admin-form-row g-1 align-items-center">
                <label class="col-6 col-lg-3 student-mgmt-admin-form-label">Code / ID</label>
                <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
                    <input class="form-control form-control-sm" type="text" placeholder="Enter code" disabled />
                </div>
                <label class="col-6 col-lg-3 student-mgmt-admin-form-label">Name</label>
                <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
                    <input class="form-control form-control-sm" type="text" placeholder="Enter name" disabled />
                </div>
            </div>
            <div class="row student-mgmt-admin-form-row g-1 align-items-center">
                <label class="col-6 col-lg-3 student-mgmt-admin-form-label">Amount / value</label>
                <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
                    <input class="form-control form-control-sm" type="text" placeholder="Enter value" disabled />
                </div>
                <label class="col-6 col-lg-3 student-mgmt-admin-form-label">Status</label>
                <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
                    <input class="form-control form-control-sm" type="text" value="Active" disabled />
                </div>
            </div>
            <div class="row student-mgmt-admin-form-row g-1 align-items-start">
                <label class="col-12 col-lg-3 student-mgmt-admin-form-label">Notes</label>
                <div class="col-12 col-lg-9 student-mgmt-admin-form-field">
                    <textarea class="form-control form-control-sm" rows="3" placeholder="Optional notes" disabled></textarea>
                </div>
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" href="/adminportal/students/@Model.Segment">Cancel</a>
        </div>
    </form>
</section>
