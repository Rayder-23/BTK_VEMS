@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";

    bool IsActive(string controller, string? action = null) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
        && (action is null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase));
}

<div class="sidebar-inner">
    <a class="portal-brand" href="/adminportal/fee">
        <span class="brand-icon"><i class="bi bi-cash-coin"></i></span>
        <span class="brand-copy">
            <span class="brand-title">Fee Management</span>
            <small>Fee &amp; challan</small>
        </span>
    </a>

    <nav class="portal-menu" aria-label="Fee management navigation">
        <a class="portal-menu-link @(IsActive("FeeRefFeeHeads") ? "active" : "")" href="/adminportal/fee/fee-heads">
            <i class="bi bi-tags" aria-hidden="true"></i><span>Fee Heads</span>
        </a>
        <a class="portal-menu-link @(IsActive("FeeStructures") ? "active" : "")" href="/adminportal/fee/fee-structures">
            <i class="bi bi-layers" aria-hidden="true"></i><span>Fee Structures</span>
        </a>
        <a class="portal-menu-link @(IsActive("FeeChallans") ? "active" : "")" href="/adminportal/fee/challans">
            <i class="bi bi-receipt-cutoff" aria-hidden="true"></i><span>Challans</span>
        </a>
        <a class="portal-menu-link @(IsActive("FeePayments") ? "active" : "")" href="/adminportal/fee/payments">
            <i class="bi bi-cash-stack" aria-hidden="true"></i><span>Payments</span>
        </a>
        <a class="portal-menu-link @(IsActive("FeePaymentReceipts") ? "active" : "")" href="/adminportal/fee/payment-receipts">
            <i class="bi bi-file-earmark-text" aria-hidden="true"></i><span>Receipts</span>
        </a>
        <a class="portal-menu-link @(IsActive("FeeConcessions") ? "active" : "")" href="/adminportal/fee/concessions">
            <i class="bi bi-percent" aria-hidden="true"></i><span>Concessions</span>
        </a>
    </nav>

    <div class="sidebar-card">
        <p class="mb-1 fw-semibold">Quick actions</p>
        <a class="small d-block text-decoration-none mb-1" href="/adminportal/fee/challans/create">
            <i class="bi bi-plus-circle me-1"></i>Generate challan
        </a>
        <a class="small d-block text-decoration-none mb-2" href="/adminportal/fee/payments/create">
            <i class="bi bi-wallet2 me-1"></i>Record payment
        </a>
        <a class="small text-decoration-none" href="/adminportal/fee">
            <i class="bi bi-grid-3x3-gap me-1"></i>Module dashboard
        </a>
    </div>
</div>

