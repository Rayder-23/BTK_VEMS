@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var isFeeHeads = string.Equals(controller, "FeeRefFeeHeads", StringComparison.OrdinalIgnoreCase);
    var isFeeStructures = string.Equals(controller, "FeeStructures", StringComparison.OrdinalIgnoreCase)
        || string.Equals(controller, "FeeStructureDetails", StringComparison.OrdinalIgnoreCase);
}

<div class="fee-erp-sidebar-inner d-flex flex-column h-100 fee-structure-mgmt-sidebar-inner">
    <div class="fee-erp-sidebar-brand px-3 py-4 border-bottom border-light border-opacity-10">
        <a href="/adminportal/fee/fee-structures" class="text-decoration-none text-white d-flex align-items-center gap-3">
            <span class="fee-erp-sidebar-logo rounded-3 d-inline-flex align-items-center justify-content-center">
                <i class="fa-solid fa-layer-group"></i>
            </span>
            <div class="fee-erp-sidebar-brand-text">
                <span class="d-block fw-bold small text-uppercase tracking-wide opacity-75">VEMS</span>
                <span class="d-block fw-semibold">Fee Structure</span>
            </div>
        </a>
    </div>

    <nav class="fee-erp-nav flex-grow-1 overflow-auto py-3 px-2" aria-label="Fee structure sections">
        <ul class="nav flex-column gap-1 fee-erp-nav-list">
            <li class="nav-item">
                <a class="fee-erp-nav-link @(isFeeHeads ? "active" : "")" href="/adminportal/fee/fee-heads">
                    <i class="fa-fw fa-solid fa-tags"></i>
                    <span class="fee-erp-nav-label">Fee Heads</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="fee-erp-nav-link @(isFeeStructures ? "active" : "")" href="/adminportal/fee/fee-structures">
                    <i class="fa-fw fa-solid fa-layer-group"></i>
                    <span class="fee-erp-nav-label">Fee Structures</span>
                </a>
            </li>
        </ul>
    </nav>

    <div class="fee-erp-sidebar-foot p-3 mt-auto border-top border-light border-opacity-10">
        <a class="fee-erp-nav-link fee-structure-mgmt-sidebar-exit border border-light border-opacity-25 bg-transparent"
           href="/adminportal/fee">
            <i class="fa-fw fa-solid fa-arrow-left"></i>
            <span class="fee-erp-nav-label">Fee Management home</span>
        </a>
        <div class="small text-white-50 mt-3 px-1 fee-structure-mgmt-sidebar-hint">
            <i class="fa-solid fa-circle-info me-1 opacity-75"></i>
            Heads and structures only — open Fee Management home for other modules.
        </div>
    </div>
</div>
