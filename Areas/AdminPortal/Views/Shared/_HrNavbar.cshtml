@model string
@{
    var adminUsername = Context.Session.GetString("AdminUsername") ?? "Admin";
}

<nav class="navbar navbar-expand-lg portal-navbar">
    <div class="container-fluid px-3 px-lg-4">
        <button class="btn btn-outline-primary d-lg-none me-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#portalSidebar" aria-controls="portalSidebar">
            <i class="bi bi-list"></i>
        </button>

        <button class="btn btn-light rounded-circle d-none d-lg-inline-flex me-3" type="button" id="hrSidebarToggle" aria-label="Collapse sidebar">
            <i class="bi bi-layout-sidebar-inset"></i>
        </button>

        <div>
            <span class="navbar-brand mb-0 h1">HR Management System</span>
            <small class="d-block text-muted">@Model</small>
        </div>

        <div class="ms-auto d-flex align-items-center gap-3">
            <a class="btn btn-light btn-sm d-none d-md-inline-flex" href="/adminportal">
                <i class="bi bi-speedometer2 me-1"></i>Admin
            </a>

            <div class="dropdown">
                <button class="btn portal-user dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="portal-user-avatar">H</span>
                    <span class="d-none d-sm-inline fw-semibold">@adminUsername</span>
                </button>
                <div class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                    <span class="dropdown-item-text small text-muted">Signed in as @adminUsername</span>
                    <div class="dropdown-divider"></div>
                    <form asp-area="AdminPortal" asp-controller="Login" asp-action="Logout" method="post">
                        <button class="dropdown-item text-danger" type="submit">
                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</nav>
