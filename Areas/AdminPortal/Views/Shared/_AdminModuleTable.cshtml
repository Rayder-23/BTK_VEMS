@model AdminModulePageViewModel

<section class="module-page-header @Model.AccentClass">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
        </ol>
    </nav>
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div class="d-flex align-items-center gap-3">
            <span class="module-page-icon"><i class="bi @Model.IconClass"></i></span>
            <div>
                <h1 class="h3 fw-bold mb-1">@Model.Title</h1>
                <p class="text-muted mb-0">@Model.Description</p>
            </div>
        </div>
        <div>
            <button class="btn btn-primary rounded-pill px-4" type="button">
                <i class="bi bi-plus-lg me-2"></i>@Model.AddButtonText
            </button>
        </div>
    </div>
</section>

<section class="portal-card mt-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4">
        <div>
            <h2 class="h5 fw-bold mb-1">@Model.Title List</h2>
            <p class="text-muted mb-0">Sample records for this admin module.</p>
        </div>
        <div class="admin-table-search">
            <i class="bi bi-search"></i>
            <input class="form-control" type="search" placeholder="Search records" aria-label="Search records" />
        </div>
    </div>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    @foreach (var header in Model.TableHeaders)
                    {
                        <th scope="col">@header</th>
                    }
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.TableRows)
                {
                    <tr>
                        @foreach (var value in row)
                        {
                            <td>@value</td>
                        }
                        <td class="text-end">
                            <div class="btn-group btn-group-sm" role="group" aria-label="Record actions">
                                <button class="btn btn-outline-primary" type="button"><i class="bi bi-eye"></i> View</button>
                                <button class="btn btn-outline-success" type="button"><i class="bi bi-pencil"></i> Edit</button>
                                <button class="btn btn-outline-danger" type="button"><i class="bi bi-trash"></i> Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
