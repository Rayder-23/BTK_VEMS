@model AdminModuleCard

@{
    var moduleUrl = Model.IsAvailable
        ? $"/adminportal/{Model.Controller.ToLowerInvariant()}"
        : "#";
    var cardClasses = $"erp-module-card h-100 {Model.AccentClass}";
    if (!Model.IsAvailable)
    {
        cardClasses += " erp-module-card--soon";
    }
}

<div class="col-12 col-md-6 col-lg-3 module-grid-item"
     data-module-name="@Model.Name"
     data-module-description="@Model.Description"
     data-module-available="@(Model.IsAvailable ? "true" : "false")">
    <a class="@cardClasses"
       href="@moduleUrl"
       @(Model.IsAvailable ? null : Html.Raw("data-soon-module=\"true\""))
       aria-label="@Model.Name module">
        <div class="erp-module-card__body">
            <span class="erp-module-card__icon" aria-hidden="true">
                <i class="bi @Model.IconClass" aria-hidden="true"></i>
            </span>
            <h3 class="erp-module-card__title">@Model.Name</h3>
            @if (!Model.IsAvailable)
            {
                <span class="erp-module-card__badge">Coming soon</span>
            }
        </div>
        <span class="erp-module-card__shine" aria-hidden="true"></span>
    </a>
</div>
