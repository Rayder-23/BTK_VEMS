<!DOCTYPE html>
@{
    var adminUsername = User.Identity?.Name ?? "Admin";
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/portals/admin-portal.css" asp-append-version="true" />
</head>
<body class="portal-shell admin-portal">
    <aside class="portal-sidebar d-none d-lg-flex">
        <partial name="_Sidebar" />
    </aside>

    <div class="offcanvas offcanvas-start portal-offcanvas" tabindex="-1" id="portalSidebar" aria-labelledby="portalSidebarLabel">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title" id="portalSidebarLabel">Admin Portal</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0">
            <partial name="_Sidebar" />
        </div>
    </div>

    <div class="portal-main">
        <nav class="navbar navbar-expand-lg portal-navbar">
            <div class="container-fluid px-3 px-lg-4">
                <button class="btn btn-outline-primary d-lg-none me-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#portalSidebar" aria-controls="portalSidebar">
                    <i class="bi bi-list"></i>
                </button>
                <div>
                    <span class="navbar-brand mb-0 h1">Admin Dashboard</span>
                    <small class="d-block text-muted">VEMS</small>
                </div>
                <div class="ms-auto d-flex align-items-center gap-2 gap-sm-3">
                    <a class="btn btn-light btn-sm d-inline-flex align-items-center" href="/adminportal" aria-label="Admin portal home" title="Admin portal home">
                        <i class="bi bi-house-door me-md-1"></i><span class="d-none d-md-inline">Admin home</span>
                    </a>
                    <button class="btn btn-light rounded-circle" type="button" aria-label="Notifications">
                        <i class="bi bi-bell"></i>
                    </button>
                    <div class="dropdown">
                        <button class="btn portal-user dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="portal-user-avatar">A</span>
                            <span class="d-none d-sm-inline fw-semibold">@adminUsername</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                            <form asp-area="AdminPortal" asp-controller="Login" asp-action="Logout" method="post">
                                <button class="dropdown-item" type="submit">
                                    <i class="bi bi-box-arrow-right me-2"></i>Logout
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </nav>

        <main class="portal-content">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
