@{
    var pageTitle = ViewData["PageTitle"] as string ?? ViewData["Title"] as string ?? "Payments";
    ViewData["FeeErpShowSidebarChrome"] = true;
    ViewData["FeeErpNavbarBrandHref"] = "/adminportal/fee/payments";
    ViewData["FeeErpNavbarBrandText"] = "Payments & Receipts";
    ViewData["FeeErpNavbarBrandIcon"] = "fa-money-check-dollar";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Payments &amp; Receipts</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
          crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/portals/admin-portal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/portals/fee-mgmt-portal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/portals/dashboard.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="fee-erp-shell payments-receipts-mgmt-shell">
    <partial name="_FeeErpNavbar" model="pageTitle" />

    <div class="fee-erp-canvas">
        <aside class="fee-erp-sidebar payments-receipts-mgmt-sidebar d-none d-lg-flex flex-column" id="feeErpSidebar" aria-label="Payments navigation">
            <partial name="_PaymentsReceiptsMgmtSidebar" />
        </aside>

        <div class="offcanvas offcanvas-start fee-erp-offcanvas text-bg-dark" tabindex="-1" id="feeErpSidebarOffcanvas"
             aria-labelledby="feeErpSidebarOffcanvasLabel">
            <div class="offcanvas-header border-bottom border-secondary border-opacity-25">
                <h5 class="offcanvas-title" id="feeErpSidebarOffcanvasLabel">
                    <i class="fa-solid fa-money-check-dollar me-2 text-info"></i>Payments &amp; Receipts
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body p-0 overflow-auto">
                <partial name="_PaymentsReceiptsMgmtSidebar" />
            </div>
        </div>

        <div class="fee-erp-main payments-receipts-mgmt-main">
            <div class="fee-erp-main-inner container-fluid py-4 px-3 px-lg-4">
                @RenderBody()
            </div>
            <footer class="fee-erp-footer">
                <div class="container-fluid px-3 px-lg-4 py-3 small text-muted">
                    <span>&copy; @DateTime.UtcNow.Year VEMS · Payments &amp; Receipts</span>
                </div>
            </footer>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
    <script src="~/js/portals/dashboard.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
