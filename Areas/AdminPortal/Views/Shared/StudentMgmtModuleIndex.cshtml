@model AdminModulePageViewModel
@{
    var segment = Model.ModuleSegment ?? "";
    var message = TempData["StatusMessage"] as string;
}

<section class="module-page-header @Model.AccentClass">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/students">Student Management</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
        </ol>
    </nav>
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div class="d-flex align-items-center gap-3">
            <span class="module-page-icon"><i class="bi @Model.IconClass" aria-hidden="true"></i></span>
            <div>
                <h1 class="h3 fw-bold mb-1">@Model.Title</h1>
                <p class="text-muted mb-0">@Model.Description</p>
            </div>
        </div>
        <a class="btn btn-primary rounded-pill px-4 align-self-lg-center" href="/adminportal/students/@segment/create">
            <i class="bi bi-plus-lg me-2"></i>@Model.AddButtonText
        </a>
    </div>
</section>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info mt-4 mb-0" role="alert">@message</div>
}

<div class="sm-notice mt-4" role="status">
    <i class="bi bi-database-slash me-2"></i>
    No database table is configured for @Model.Title yet. Links below open CRUD screens with sample data.
</div>

<section class="portal-card mt-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4">
        <div>
            <h2 class="h5 fw-bold mb-1">@Model.Title list</h2>
            <p class="text-muted mb-0">Sample records until database schema is added.</p>
        </div>
        <div class="admin-table-search">
            <i class="bi bi-search"></i>
            <input class="form-control" type="search" placeholder="Search records" aria-label="Search records" disabled />
        </div>
    </div>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    @foreach (var header in Model.TableHeaders)
                    {
                        <th scope="col">@header</th>
                    }
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ var rowIndex = 1; }
                @foreach (var row in Model.TableRows)
                {
                    <tr>
                        @foreach (var value in row)
                        {
                            <td>@value</td>
                        }
                        <td class="text-end">
                            <div class="d-inline-flex flex-wrap justify-content-end gap-1">
                                <a class="btn btn-outline-success btn-sm" href="/adminportal/students/@segment/edit/@rowIndex">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <form method="post" action="/adminportal/students/@segment/delete/@rowIndex" class="d-inline"
                                      onsubmit="return confirm('Delete this record?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    rowIndex++;
                }
            </tbody>
        </table>
    </div>
</section>

