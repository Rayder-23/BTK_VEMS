@using VEMS.Areas.AdminPortal.Services.Admissions
@{
    var path = Context.Request.Path.Value ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var activeKey = AdmissionsNavCatalog.ResolveActiveKey(path, action);
}
<div class="fee-erp-sidebar-inner d-flex flex-column h-100 admissions-mgmt-sidebar-inner">
    <div class="fee-erp-sidebar-brand px-3 py-4 border-bottom border-light border-opacity-10">
        <a href="/adminportal/admissions" class="text-decoration-none text-white d-flex align-items-center gap-3">
            <span class="fee-erp-sidebar-logo rounded-3 d-inline-flex align-items-center justify-content-center">
                <i class="fa-solid fa-door-open"></i>
            </span>
            <div class="fee-erp-sidebar-brand-text">
                <span class="d-block fw-bold small text-uppercase tracking-wide opacity-75">VEMS</span>
                <span class="d-block fw-semibold">Admissions</span>
            </div>
        </a>
    </div>
    <nav class="fee-erp-nav flex-grow-1 overflow-auto py-3 px-2" aria-label="Admissions navigation">
        <ul class="nav flex-column gap-1 fee-erp-nav-list">
            @foreach (var item in AdmissionsNavCatalog.SidebarNav)
            {
                <li class="nav-item">
                    <a class="fee-erp-nav-link @(activeKey == item.Key ? "active" : "")" href="@item.Url">
                        <i class="fa-fw fa-solid @item.IconClass"></i>
                        <span class="fee-erp-nav-label">@item.Name</span>
                    </a>
                </li>
            }
        </ul>
    </nav>
    <div class="fee-erp-sidebar-foot p-3 mt-auto border-top border-light border-opacity-10">
        <a class="fee-erp-nav-link border border-light border-opacity-25 bg-transparent" href="/adminportal">
            <i class="fa-fw fa-solid fa-arrow-left"></i>
            <span class="fee-erp-nav-label">Admin portal home</span>
        </a>
    </div>
</div>
