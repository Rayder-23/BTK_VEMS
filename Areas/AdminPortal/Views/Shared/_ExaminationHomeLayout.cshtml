@{
    var pageTitle = ViewData["PageTitle"] as string ?? ViewData["Title"] as string ?? "Examination";
    ViewData["FeeErpShowSidebarChrome"] = false;
    ViewData["FeeErpNavbarBrandHref"] = "/adminportal/examination";
    ViewData["FeeErpNavbarBrandText"] = "Examination Module";
    ViewData["FeeErpNavbarBrandIcon"] = "fa-pen-ruler";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Examination</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
          crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/portals/admin-portal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/portals/fee-mgmt-portal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/portals/dashboard.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="fee-erp-shell examination-home-shell fee-erp-home-shell">
    <partial name="_FeeErpNavbar" model="pageTitle" />

    <main class="fee-erp-home-main container-fluid px-3 px-lg-4 py-4">
        @RenderBody()
    </main>

    <footer class="fee-erp-footer fee-erp-home-footer border-top bg-white">
        <div class="container-fluid px-3 px-lg-4 py-3 small text-muted">
            <span>&copy; @DateTime.UtcNow.Year VEMS · Examination</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
    <script src="~/js/portals/dashboard.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
