<!DOCTYPE html>
@{
    var pageTitle = ViewData["PageTitle"] as string ?? ViewData["Title"] as string ?? "Student Management";
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Management</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/portals/admin-portal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/portals/student-mgmt-portal.css" asp-append-version="true" />
</head>
<body class="portal-shell student-mgmt-portal admin-portal">
    <aside class="portal-sidebar d-none d-lg-flex" id="studentMgmtSidebar">
        <partial name="_StudentMgmtModuleSidebar" />
    </aside>

    <div class="offcanvas offcanvas-start portal-offcanvas" tabindex="-1" id="portalSidebar" aria-labelledby="portalSidebarLabel">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title" id="portalSidebarLabel">Student Management</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0">
            <partial name="_StudentMgmtModuleSidebar" />
        </div>
    </div>

    <div class="portal-main">
        <partial name="_StudentMgmtNavbar" model="pageTitle" />

        <main class="portal-content">
            @RenderBody()
        </main>

        <partial name="_AdminFooter" />
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
    <script>
        const sidebarToggle = document.getElementById('studentMgmtSidebarToggle');
        sidebarToggle?.addEventListener('click', () => {
            document.body.classList.toggle('sidebar-collapsed');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
