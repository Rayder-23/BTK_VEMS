@model EmployeeFormModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row g-3">
    <div class="col-12 col-lg-6">
        <label asp-for="EmployeeId" class="form-label"></label>
        <input asp-for="EmployeeId" class="form-control" autocomplete="off" />
        <span asp-validation-for="EmployeeId" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="FullName" class="form-label"></label>
        <input asp-for="FullName" class="form-control" autocomplete="name" />
        <span asp-validation-for="FullName" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" type="email" autocomplete="email" />
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="Phone" class="form-label"></label>
        <input asp-for="Phone" class="form-control" autocomplete="tel" />
        <span asp-validation-for="Phone" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="CNIC" class="form-label"></label>
        <input asp-for="CNIC" class="form-control" />
        <span asp-validation-for="CNIC" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="FatherName" class="form-label"></label>
        <input asp-for="FatherName" class="form-control" />
        <span asp-validation-for="FatherName" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="DOB" class="form-label"></label>
        <input asp-for="DOB" class="form-control" type="date" />
        <span asp-validation-for="DOB" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="Department" class="form-label"></label>
        <input asp-for="Department" class="form-control" />
        <span asp-validation-for="Department" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="Designation" class="form-label"></label>
        <input asp-for="Designation" class="form-control" />
        <span asp-validation-for="Designation" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="Specialization" class="form-label"></label>
        <input asp-for="Specialization" class="form-control" />
        <span asp-validation-for="Specialization" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="Qualification" class="form-label"></label>
        <input asp-for="Qualification" class="form-control" />
        <span asp-validation-for="Qualification" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="EmployeeType" class="form-label"></label>
        <input asp-for="EmployeeType" class="form-control" />
        <span asp-validation-for="EmployeeType" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="Status" class="form-label"></label>
        <input asp-for="Status" class="form-control" />
        <span asp-validation-for="Status" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="JoinedDate" class="form-label"></label>
        <input asp-for="JoinedDate" class="form-control" type="date" />
        <span asp-validation-for="JoinedDate" class="text-danger small"></span>
    </div>
    <div class="col-12">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Notes" class="text-danger small"></span>
    </div>
</div>
