@model EmployeeFormModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row g-3">
    <div class="col-12 col-lg-6">
        <label asp-for="EmployeeID" class="form-label"></label>
        <input asp-for="EmployeeID" class="form-control" autocomplete="off" />
        <span asp-validation-for="EmployeeID" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="EmployeeName" class="form-label"></label>
        <input asp-for="EmployeeName" class="form-control" />
        <span asp-validation-for="EmployeeName" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="CNIC" class="form-label"></label>
        <input asp-for="CNIC" class="form-control" />
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="FatherName" class="form-label"></label>
        <input asp-for="FatherName" class="form-control" />
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="DOB" class="form-label"></label>
        <input asp-for="DOB" class="form-control" />
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="MobileNo" class="form-label"></label>
        <input asp-for="MobileNo" class="form-control" />
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="Department" class="form-label"></label>
        <input asp-for="Department" class="form-control" />
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="Designation" class="form-label"></label>
        <input asp-for="Designation" class="form-control" />
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="DateOfJoining" class="form-label"></label>
        <input asp-for="DateOfJoining" class="form-control" type="date" />
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="EmployeeStatus" class="form-label"></label>
        <input asp-for="EmployeeStatus" class="form-control" />
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="Project" class="form-label"></label>
        <input asp-for="Project" class="form-control" />
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="GenStatus" class="form-label"></label>
        <input asp-for="GenStatus" class="form-control" />
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="BasicSalary" class="form-label"></label>
        <input asp-for="BasicSalary" class="form-control" type="number" step="0.01" />
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="ApplyTax" class="form-label"></label>
        <input asp-for="ApplyTax" class="form-control" />
    </div>
    <div class="col-12 col-lg-4">
        <label asp-for="CarryForwardLeaves" class="form-label"></label>
        <input asp-for="CarryForwardLeaves" class="form-control" type="number" step="any" />
    </div>
    <div class="col-12 col-lg-4">
        <label asp-for="Year2022" class="form-label"></label>
        <input asp-for="Year2022" class="form-control" type="number" step="any" />
    </div>
    <div class="col-12 col-lg-4">
        <label asp-for="Year2023" class="form-label"></label>
        <input asp-for="Year2023" class="form-control" type="number" step="any" />
    </div>
    <div class="col-12 col-lg-4">
        <label asp-for="AdjustedAjusted" class="form-label"></label>
        <input asp-for="AdjustedAjusted" class="form-control" type="number" />
    </div>
    <div class="col-12 col-lg-4">
        <label asp-for="Year2024" class="form-label"></label>
        <input asp-for="Year2024" class="form-control" type="number" />
    </div>
    <div class="col-12 col-lg-4">
        <label asp-for="CarryForwardLeaves1" class="form-label"></label>
        <input asp-for="CarryForwardLeaves1" class="form-control" type="number" step="any" />
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="Year2023New" class="form-label"></label>
        <input asp-for="Year2023New" class="form-control" type="number" step="0.01" />
    </div>
    <div class="col-12">
        <label asp-for="Details" class="form-label"></label>
        <textarea asp-for="Details" class="form-control" rows="3"></textarea>
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="ModifiedBy" class="form-label"></label>
        <input asp-for="ModifiedBy" class="form-control" readonly />
        <div class="form-text">Set automatically when you save.</div>
    </div>
    <div class="col-12 col-lg-6">
        <label asp-for="ModifiedOn" class="form-label"></label>
        <input asp-for="ModifiedOn" class="form-control" readonly />
    </div>
</div>
