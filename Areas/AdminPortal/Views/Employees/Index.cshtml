@model IReadOnlyList<EmployeeListItemViewModel>
@{
    ViewData["Title"] = "Employees";
    var message = TempData["StatusMessage"] as string;
    var error = TempData["ErrorMessage"] as string;
}

<section class="module-page-header accent-green">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/hr">HR</a></li>
            <li class="breadcrumb-item active" aria-current="page">Employees</li>
        </ol>
    </nav>
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center">
        <div class="d-flex align-items-center gap-3">
            <span class="module-page-icon"><i class="bi bi-person-badge-fill"></i></span>
            <div>
                <h1 class="h3 fw-bold mb-1">Employees</h1>
                <p class="text-muted mb-0">Create, update, and remove records in <code>dbo.Employee</code>.</p>
            </div>
        </div>
        <a class="btn btn-primary rounded-pill px-4" asp-action="Create">
            <i class="bi bi-plus-lg me-2"></i>Add employee
        </a>
    </div>
</section>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mt-4 mb-0" role="alert">@message</div>
}
@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger mt-4 mb-0" role="alert">@error</div>
}

<section class="portal-card mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-3">
        <div>
            <h2 class="h5 fw-bold mb-1">Directory</h2>
            <p class="text-muted mb-0">@Model.Count employee(s).</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Employee ID</th>
                    <th scope="col">Name</th>
                    <th scope="col">Department</th>
                    <th scope="col">Designation</th>
                    <th scope="col">Status</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-muted py-4 text-center">No employees yet. Add one to get started.</td>
                </tr>
            }
            @foreach (var e in Model)
            {
                <tr>
                    <td>@e.Uid</td>
                    <td>@e.EmployeeId</td>
                    <td>@e.FullName</td>
                    <td>@(e.Department ?? "—")</td>
                    <td>@(e.Designation ?? "—")</td>
                    <td>@e.Status</td>
                    <td class="text-end">
                        <div class="d-inline-flex flex-wrap justify-content-end gap-1">
                            <a class="btn btn-outline-success btn-sm" asp-action="Edit" asp-route-id="@e.Uid"><i class="bi bi-pencil"></i> Edit</a>
                            <form asp-action="Delete" asp-route-id="@e.Uid" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this employee? This cannot be undone.');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i> Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
