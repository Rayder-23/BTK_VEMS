@model VEMS.Areas.AdminPortal.Models.Fee.FeeStructureDetailsPageModel
@{
    ViewData["Title"] = "Structure Details";
    var feeHeads = ViewData["FeeHeads"] as IReadOnlyList<FeeLookupItem> ?? Array.Empty<FeeLookupItem>();
    var s = Model.Structure;
}

<section class="module-page-header accent-orange">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal/fee/fee-structures">Structures</a></li>
            <li class="breadcrumb-item active">@s.StructureName</li>
        </ol>
    </nav>
    <h1 class="h3 fw-bold mb-1">@s.StructureName</h1>
    <p class="text-muted mb-0">
        @s.ProgramName
        @if (!string.IsNullOrWhiteSpace(s.ClassName))
        {
            <text> · @s.ClassName</text>
        }
        · @s.Semester · @s.AcademicYear
    </p>
</section>

<partial name="_FeeAlerts" />

<section class="portal-card mt-4">
    <h2 class="h5 fw-bold">Line items</h2>
    <div class="table-responsive mt-3">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>Fee head</th>
                    <th>Amount</th>
                    <th>Due date</th>
                    <th>Late fine/day</th>
                    <th>Max late fine</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var line in Model.Lines)
            {
                <tr>
                    <td>@line.FeeHeadName</td>
                    <td>@line.Amount.ToString("N2")</td>
                    <td>@(line.DueDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                    <td>@line.LateFinePerDay.ToString("N2")</td>
                    <td>@line.MaxLateFine.ToString("N2")</td>
                    <td class="text-end">
                        <form method="post" action="/adminportal/fee/fee-structures/details/@s.Uid/delete-line/@line.Uid"
                              onsubmit="return confirm('Remove this line?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>

<section class="portal-card mt-4">
    <h2 class="h5 fw-bold">Add fee head</h2>
    <form method="post" action="/adminportal/fee/fee-structures/details/@s.Uid/add-line" class="mt-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="StructureId" value="@s.Uid" />
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label" for="FeeHeadId">Fee head</label>
                <select class="form-select" id="FeeHeadId" name="FeeHeadId" required>
                    <option value="">— Select —</option>
                    @foreach (var h in feeHeads)
                    {
                        <option value="@h.Id">@h.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label" for="Amount">Amount</label>
                <input class="form-control" id="Amount" name="Amount" type="number" step="0.01" min="0" required />
            </div>
            <div class="col-md-2">
                <label class="form-label" for="DueDate">Due date</label>
                <input class="form-control" id="DueDate" name="DueDate" type="date" />
            </div>
            <div class="col-md-2">
                <label class="form-label" for="LateFinePerDay">Late fine/day</label>
                <input class="form-control" id="LateFinePerDay" name="LateFinePerDay" type="number" step="0.01" min="0" value="0" />
            </div>
            <div class="col-md-2">
                <label class="form-label" for="MaxLateFine">Max late fine</label>
                <input class="form-control" id="MaxLateFine" name="MaxLateFine" type="number" step="0.01" min="0" value="0" />
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary">Add line</button>
            </div>
        </div>
    </form>
</section>
