@model IReadOnlyList<VEMS.Areas.AdminPortal.Models.Fee.FeeStructureListItem>
@{
    ViewData["Title"] = "Fee Structures";
}

<section class="module-page-header accent-orange">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal/fee">Fee</a></li>
            <li class="breadcrumb-item active">Fee Structures</li>
        </ol>
    </nav>
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center">
        <h1 class="h3 fw-bold mb-0">Fee Structures</h1>
        <a class="btn btn-primary rounded-pill" href="/adminportal/fee/fee-structures/create">Add structure</a>
    </div>
</section>

<partial name="_FeeAlerts" />

<section class="portal-card mt-4">
    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Program</th>
                    <th>Semester</th>
                    <th>Year</th>
                    <th>Lines</th>
                    <th>Total</th>
                    <th>Active</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.StructureName</td>
                    <td>@row.ProgramName</td>
                    <td>@row.Semester</td>
                    <td>@row.AcademicYear</td>
                    <td>@row.DetailCount</td>
                    <td>@row.TotalAmount.ToString("N2")</td>
                    <td>@(row.IsActive ? "Yes" : "No")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" href="/adminportal/fee/fee-structures/details/@row.Uid">Details</a>
                        <a class="btn btn-sm btn-outline-success" href="/adminportal/fee/fee-structures/edit/@row.Uid">Edit</a>
                        @if (row.IsActive)
                        {
                            <form method="post" action="/adminportal/fee/fee-structures/deactivate/@row.Uid" class="d-inline"
                                  onsubmit="return confirm('Deactivate this structure?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Deactivate</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
