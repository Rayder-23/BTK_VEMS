@model VEMS.Areas.AdminPortal.Models.Fee.ConcessionFormModel
@using VEMS.Areas.AdminPortal.Models.Fee
@{
    var students = ViewData["Students"] as IReadOnlyList<FeeLookupItem> ?? Array.Empty<FeeLookupItem>();
    var feeHeads = ViewData["FeeHeads"] as IReadOnlyList<FeeLookupItem> ?? Array.Empty<FeeLookupItem>();
}

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="StudentId" class="form-label"></label>
        <select asp-for="StudentId" class="form-select" asp-items="@(new SelectList(students, "Id", "Name"))"></select>
    </div>
    <div class="col-md-6">
        <label asp-for="FeeHeadId" class="form-label"></label>
        <select asp-for="FeeHeadId" class="form-select">
            <option value="">All fee heads</option>
            @foreach (var h in feeHeads)
            {
                <option value="@h.Id" selected="@(Model.FeeHeadId == h.Id)">@h.Name</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="ConcessionType" class="form-label"></label>
        <select asp-for="ConcessionType" class="form-select" asp-items="@(new SelectList(FeeConstants.ConcessionTypes))"></select>
    </div>
    <div class="col-md-4">
        <label asp-for="DiscountPercent" class="form-label"></label>
        <input asp-for="DiscountPercent" class="form-control" type="number" step="0.01" />
    </div>
    <div class="col-md-4">
        <label asp-for="DiscountAmount" class="form-label"></label>
        <input asp-for="DiscountAmount" class="form-control" type="number" step="0.01" />
    </div>
    <div class="col-md-4">
        <label asp-for="ValidFrom" class="form-label"></label>
        <input asp-for="ValidFrom" class="form-control" type="date" />
    </div>
    <div class="col-md-4">
        <label asp-for="ValidTo" class="form-label"></label>
        <input asp-for="ValidTo" class="form-control" type="date" />
    </div>
    <div class="col-md-4">
        <label asp-for="ApprovedBy" class="form-label"></label>
        <input asp-for="ApprovedBy" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="ApprovalDate" class="form-label"></label>
        <input asp-for="ApprovalDate" class="form-control" type="date" />
    </div>
    <div class="col-12">
        <label asp-for="Remarks" class="form-label"></label>
        <textarea asp-for="Remarks" class="form-control" rows="2"></textarea>
    </div>
    <div class="col-md-4">
        <div class="form-check mt-2">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label">Active</label>
        </div>
    </div>
</div>
