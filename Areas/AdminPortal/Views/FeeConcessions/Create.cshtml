@model VEMS.Areas.AdminPortal.Models.Fee.ConcessionFormModel
@{ ViewData["Title"] = "Add Concession"; }
<section class="module-page-header accent-purple"><h1 class="h3 fw-bold">Add concession</h1></section>
<partial name="_FeeAlerts" />
<section class="portal-card mt-4">
    <form method="post">
        @Html.AntiForgeryToken()
        <partial name="_ConcessionForm" />
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" href="/adminportal/fee/concessions">Cancel</a>
        </div>
    </form>
</section>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
