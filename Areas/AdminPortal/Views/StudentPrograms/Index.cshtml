@model IReadOnlyList<VEMS.Areas.AdminPortal.Models.ProgramListItem>
@{
    var search = ViewData["Search"] as string;
    var showInactive = ViewData["ShowInactive"] as bool? ?? false;
    var message = TempData["StatusMessage"] as string;
}

<section class="portal-card page-summary-compact mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/students">Student Management</a></li>
            <li class="breadcrumb-item active">Programs</li>
        </ol>
    </nav>
    <div class="page-summary-head">
        <div class="page-summary-title-block">
            <span class="page-summary-title">Programs</span>
            <span class="page-summary-meta">Manage dbo.ref_Programs</span>
        </div>
        <div class="d-flex flex-wrap gap-2 flex-shrink-0">
            <a class="btn btn-sm btn-outline-primary rounded-pill" href="/adminportal/students/programs/courses">
                <i class="bi bi-grid me-1"></i>Courses by program
            </a>
            <a class="btn btn-sm btn-primary rounded-pill" href="/adminportal/students/programs/create">
                <i class="bi bi-plus-lg me-1"></i>Add program
            </a>
        </div>
    </div>
</section>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mb-3" role="alert">@message</div>
}

<section class="portal-card">
    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-md-6">
            <label class="form-label" for="search">Search</label>
            <input type="search" class="form-control" id="search" name="search" value="@search" placeholder="Code, name, institution type" />
        </div>
        <div class="col-md-3">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="showInactive" value="true" id="showInactive" @(showInactive ? "checked" : "") />
                <label class="form-check-label" for="showInactive">Show inactive</label>
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Institution type</th>
                    <th>Degree level</th>
                    <th>Status</th>
                    <th>Active</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="7" class="text-center text-muted py-4">No programs found.</td></tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.ProgramCode</td>
                    <td>@row.ProgramName</td>
                    <td>@row.InstitutionTypeName</td>
                    <td>@(row.DegreeLevel ?? "—")</td>
                    <td>@row.Status</td>
                    <td>@(row.IsActive ? "Yes" : "No")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" href="/adminportal/students/programs/details/@row.Uid">View</a>
                        <a class="btn btn-sm btn-outline-success" href="/adminportal/students/programs/edit/@row.Uid">Edit</a>
                        @if (row.IsActive)
                        {
                            <form method="post" action="/adminportal/students/programs/delete/@row.Uid" class="d-inline"
                                  onsubmit="return confirm('Deactivate this program?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Deactivate</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
