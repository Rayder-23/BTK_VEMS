@model VEMS.Areas.AdminPortal.Models.ProgramCoursesPageViewModel
@using VEMS.Areas.AdminPortal.Models
@{
    var search = Model.Search;
    var showInactive = Model.ShowInactive;
    var programId = Model.SelectedProgramId;
    var summary = Model.ProgramSummary;
    var program = Model.Program;
}

<section class="portal-card page-summary-compact mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/adminportal/students">Student Management</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/students/programs">Programs</a></li>
            <li class="breadcrumb-item active">@(programId.HasValue ? "Program courses" : "Courses by program")</li>
        </ol>
    </nav>
    <div class="page-summary-head">
        <div class="page-summary-title-block">
            <span class="page-summary-title">@(programId.HasValue ? summary?.ProgramName ?? "Program courses" : "Courses by program")</span>
            <span class="page-summary-meta">Courses linked via dbo.Courses.ProgramID</span>
        </div>
        @if (programId.HasValue)
        {
            <div class="d-flex flex-wrap gap-2 flex-shrink-0">
                <a class="btn btn-sm btn-outline-secondary rounded-pill" href="/adminportal/students/programs/edit/@programId">Edit program</a>
                <a class="btn btn-sm btn-primary rounded-pill" href="/adminportal/students/courses/create?programId=@programId">
                    <i class="bi bi-plus-lg me-1"></i>Add course
                </a>
            </div>
        }
    </div>
</section>

<section class="portal-card mb-3">
    <form method="get" action="/adminportal/students/programs/courses" class="row g-2 align-items-end">
        <div class="col-md-5">
            <label class="form-label" for="programId">Program</label>
            <select class="form-select" id="programId" name="programId"
                    asp-items="@(new SelectList(Model.Programs, nameof(StudentLookupItem.Id), nameof(StudentLookupItem.Name), programId))">
                <option value="">— Select program —</option>
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label" for="search">Search courses</label>
            <input type="search" class="form-control" id="search" name="search" value="@search" placeholder="Code or title" />
        </div>
        <div class="col-md-1">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="showInactive" value="true" id="showInactive" @(showInactive ? "checked" : "") />
                <label class="form-check-label" for="showInactive">Inactive</label>
            </div>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-primary w-100">Load</button>
        </div>
    </form>
</section>

@if (programId.HasValue && summary is not null && program is not null)
{
    <section class="portal-card mb-3">
        <h2 class="h6 fw-bold mb-3">Program record</h2>
        <div class="row g-3 small">
            <div class="col-md-2"><span class="text-muted">Code</span><div class="fw-semibold">@summary.ProgramCode</div></div>
            <div class="col-md-4"><span class="text-muted">Name</span><div class="fw-semibold">@summary.ProgramName</div></div>
            <div class="col-md-2"><span class="text-muted">Short name</span><div>@(summary.ShortName ?? "—")</div></div>
            <div class="col-md-2"><span class="text-muted">Duration</span><div>@(summary.DurationYears.HasValue ? $"{summary.DurationYears} yr(s)" : "—")</div></div>
            <div class="col-md-1"><span class="text-muted">Active</span><div>@(summary.IsActive ? "Yes" : "No")</div></div>
            <div class="col-md-2"><span class="text-muted">Created</span><div>@summary.CreatedAt.ToString("yyyy-MM-dd")</div></div>
        </div>
    </section>

    <section class="portal-card">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h6 fw-bold mb-0">Courses (@Model.Courses.Count)</h2>
        </div>
        <div class="table-responsive">
            <table class="table admin-table align-middle">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Title</th>
                        <th>Credits</th>
                        <th>Semester</th>
                        <th>Mandatory</th>
                        <th>Active</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Courses.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No courses for this program.</td></tr>
                }
                @foreach (var row in Model.Courses)
                {
                    <tr>
                        <td>@row.CourseCode</td>
                        <td>@row.CourseTitle</td>
                        <td>@row.CreditHours</td>
                        <td>@(row.SemesterNo?.ToString() ?? "—")</td>
                        <td>@(row.IsMandatory ? "Yes" : "No")</td>
                        <td>@(row.IsActive ? "Yes" : "No")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-success" href="/adminportal/students/courses/edit/@row.Uid">Edit</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
}
else
{
    <section class="portal-card">
        <p class="text-muted mb-0 text-center py-4">Select a program from the dropdown and click Load to view its courses.</p>
    </section>
}
