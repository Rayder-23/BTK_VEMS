@model IReadOnlyList<VEMS.Areas.AdminPortal.Services.HrNavItem>
@{
    ViewData["Title"] = "Dashboard";
    ViewData["PageTitle"] = "HR Management · Dashboard";
}

<h1 class="h4 fw-bold mb-3">Dashboard</h1>

<p class="text-muted mb-4">Employees, payroll, leaves, attendance, tax, allowances, and deductions. Employee records use the live <code>dbo.Employee</code> table.</p>

<section class="portal-card">
    <h2 class="h6 fw-bold mb-3">HR modules</h2>
    <div class="row g-3 hr-module-grid">
        @foreach (var module in Model)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <a class="hr-module-card @module.AccentClass" href="@module.Url">
                    <span class="hr-module-card__icon @module.AccentClass">
                        <i class="bi @module.IconClass"></i>
                    </span>
                    <h3 class="hr-module-card__title">@module.Name</h3>
                    <p class="hr-module-card__desc">@module.Description</p>
                </a>
            </div>
        }
    </div>
</section>
