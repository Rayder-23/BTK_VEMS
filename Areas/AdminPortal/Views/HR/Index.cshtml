@model IReadOnlyList<VEMS.Areas.AdminPortal.Services.HrNavItem>
@{
    ViewData["Title"] = "HR Management";
}

<section class="module-page-header accent-teal">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item active" aria-current="page">HR Management</li>
        </ol>
    </nav>
    <div class="d-flex align-items-center gap-3">
        <span class="module-page-icon"><i class="bi bi-diagram-3-fill"></i></span>
        <div>
            <h1 class="h3 fw-bold mb-1">HR Management</h1>
            <p class="text-muted mb-0">Employees, payroll, leaves, attendance, tax, allowances, and deductions.</p>
        </div>
    </div>
</section>

<div class="hr-notice mt-4" role="status">
  <i class="bi bi-info-circle me-2"></i>
  Modules without database tables show sample lists and CRUD screens. Employee records use the live <code>dbo.Employee</code> table.
</div>

<section class="portal-card mt-4">
    <h2 class="h5 fw-bold mb-3">HR modules</h2>
    <div class="row g-3 hr-module-grid">
        @foreach (var module in Model)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <a class="hr-module-card @module.AccentClass" href="@module.Url">
                    <span class="hr-module-card__icon @module.AccentClass">
                        <i class="bi @module.IconClass"></i>
                    </span>
                    <h3 class="hr-module-card__title">@module.Name</h3>
                    <p class="hr-module-card__desc">@module.Description</p>
                </a>
            </div>
        }
    </div>
</section>
