@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var hrControllers = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "HR", "Employees", "Leaves", "HrAttendance", "Payroll", "Tax", "Allowances", "Deductions"
    };

    Layout = hrControllers.Contains(controller)
        ? "/Areas/AdminPortal/Views/Shared/_HrLayout.cshtml"
        : "/Areas/AdminPortal/Views/Shared/_AdminLayout.cshtml";
}
