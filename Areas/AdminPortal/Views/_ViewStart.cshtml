@using VEMS.Areas.AdminPortal.Services
@using VEMS.Areas.AdminPortal.Services.Admissions
@using VEMS.Areas.AdminPortal.Services.Examination
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

    if (TeachersNavCatalog.IsTeachersController(controller))
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_TeachersMgmtLayout.cshtml";
    }
    else if (string.Equals(controller, "StudentMgmt", StringComparison.OrdinalIgnoreCase)
        || StudentMgmtNavCatalog.IsStudentMgmtController(controller))
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_StudentMgmtMgmtLayout.cshtml";
    }
    else if (AdmissionsNavCatalog.IsAdmissionsController(controller))
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_AdmissionsMgmtLayout.cshtml";
    }
    else if (ExaminationNavCatalog.IsExaminationController(controller))
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_ExaminationMgmtLayout.cshtml";
    }
    else if (FeeMgmtNavCatalog.IsFeeMgmtController(controller))
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_FeeMgmtMgmtLayout.cshtml";
    }
    else if (SettingsNavCatalog.IsSettingsController(controller))
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_SettingsMgmtLayout.cshtml";
    }
    else if (AccountsNavCatalog.IsAccountsController(controller))
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_AccountsMgmtLayout.cshtml";
    }
    else if (HrNavCatalog.IsHrController(controller))
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_HrMgmtLayout.cshtml";
    }
    else
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_AdminLayout.cshtml";
    }
}
