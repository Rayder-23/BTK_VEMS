@using VEMS.Areas.AdminPortal.Services
@using VEMS.Areas.AdminPortal.Services.Admissions
@using VEMS.Areas.AdminPortal.Services.Examination
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var hrControllers = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "HR", "Employees", "Leaves", "HrAttendance", "Payroll", "Tax", "Allowances", "Deductions"
    };

    if (string.Equals(controller, "StudentMgmt", StringComparison.OrdinalIgnoreCase))
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_StudentMgmtHomeLayout.cshtml";
    }
    else if (StudentMgmtModuleCatalog.TryGetByController(controller) is not null)
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_StudentMgmtModuleLayout.cshtml";
    }
    else if (AdmissionsNavCatalog.IsAdmissionsController(controller))
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_AdmissionsMgmtLayout.cshtml";
    }
    else if (string.Equals(controller, "ExaminationMgmt", StringComparison.OrdinalIgnoreCase))
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_ExaminationHomeLayout.cshtml";
    }
    else if (ExaminationModuleCatalog.TryGetByController(controller) is not null)
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_ExaminationMgmtLayout.cshtml";
    }
    else if (string.Equals(controller, "FeeMgmt", StringComparison.OrdinalIgnoreCase))
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_FeeErpHomeLayout.cshtml";
    }
    else if (string.Equals(controller, "FeeChallans", StringComparison.OrdinalIgnoreCase)
        || string.Equals(controller, "FeeChallanDetails", StringComparison.OrdinalIgnoreCase))
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_ChallanMgmtLayout.cshtml";
    }
    else if (string.Equals(controller, "FeeRefFeeHeads", StringComparison.OrdinalIgnoreCase)
        || string.Equals(controller, "FeeStructures", StringComparison.OrdinalIgnoreCase)
        || string.Equals(controller, "FeeStructureDetails", StringComparison.OrdinalIgnoreCase))
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_FeeStructureMgmtLayout.cshtml";
    }
    else if (string.Equals(controller, "FeePayments", StringComparison.OrdinalIgnoreCase)
        || string.Equals(controller, "FeePaymentReceipts", StringComparison.OrdinalIgnoreCase)
        || string.Equals(controller, "FeeConcessions", StringComparison.OrdinalIgnoreCase))
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_PaymentsReceiptsMgmtLayout.cshtml";
    }
    else if (FeeMgmtModuleCatalog.TryGetByController(controller) is not null)
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_FeeErpLayout.cshtml";
    }
    else if (hrControllers.Contains(controller))
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_HrLayout.cshtml";
    }
    else
    {
        Layout = "/Areas/AdminPortal/Views/Shared/_AdminLayout.cshtml";
    }
}
