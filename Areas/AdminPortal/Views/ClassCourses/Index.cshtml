@model IReadOnlyList<ClassCourseListItem>
@{
    ViewData["Title"] = "Class section courses";
    var search = ViewData["Search"] as string;
    var message = TempData["StatusMessage"] as string;
    var error = TempData["ErrorMessage"] as string;
}

<section class="module-page-header accent-teal">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/students">Student Management</a></li>
            <li class="breadcrumb-item active" aria-current="page">Class Section Courses</li>
        </ol>
    </nav>
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center">
        <div class="d-flex align-items-center gap-3">
            <span class="module-page-icon"><i class="bi bi-collection"></i></span>
            <div>
                <h1 class="h3 fw-bold mb-1">Class section courses</h1>
                <p class="text-muted mb-0">Link courses to class sections in <code>dbo.ClassSectionCourses</code>.</p>
            </div>
        </div>
        <a class="btn btn-primary rounded-pill px-4" asp-action="Create">
            <i class="bi bi-plus-lg me-2"></i>Assign course
        </a>
    </div>
</section>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-warning mt-4 mb-0" role="alert">@error</div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mt-4 mb-0" role="alert">@message</div>
}

<section class="portal-card mt-4">
    <form method="get" class="row g-2 align-items-end mb-3" asp-action="Index">
        <div class="col-md-9">
            <label class="form-label" for="search">Search</label>
            <input type="search" class="form-control" id="search" name="search" value="@search"
                   placeholder="Year, class, section, course" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-sm admin-table admin-table-compact align-middle mb-0">
            <thead>
                <tr>
                    <th>Year</th>
                    <th>Class</th>
                    <th>Section</th>
                    <th>Course</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="5" class="text-center text-muted py-4">No class section course links found.</td></tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.YearName</td>
                    <td>@row.ClassName</td>
                    <td>@row.SectionName</td>
                    <td>
                        <div class="fw-semibold">@row.CourseCode</div>
                        <div class="small text-muted">@row.CourseName</div>
                    </td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@row.ClassSectionCourseId">Edit</a>
                        <form method="post" asp-action="Delete" asp-route-id="@row.ClassSectionCourseId" class="d-inline"
                              onsubmit="return confirm('Delete this class section course link?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
