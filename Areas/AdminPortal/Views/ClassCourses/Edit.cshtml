@model ClassCourseFormPageViewModel
@{
    ViewData["Title"] = "Edit class course";
}

<section class="module-page-header accent-teal">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/students">Student Management</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Class Courses</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit</li>
        </ol>
    </nav>
    <h1 class="h3 fw-bold mb-0">Edit class course</h1>
    <p class="text-muted mb-0 mt-2">Internal id: <strong>@Model.Form.Uid</strong></p>
</section>

<section class="portal-card mt-4">
    <form asp-action="Edit" method="post" novalidate>
        @Html.AntiForgeryToken()
        <partial name="_ClassCourseForm" model="Model" />
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Save changes</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Back to list</a>
        </div>
    </form>
</section>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
}
