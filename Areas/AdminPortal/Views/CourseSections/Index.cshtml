@model IReadOnlyList<CourseSectionListItem>
@{
    ViewData["Title"] = "Uni course sections";
    var search = ViewData["Search"] as string;
    var message = TempData["StatusMessage"] as string;
    var error = TempData["ErrorMessage"] as string;
}

<div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center mb-3">
    <div>
        <h1 class="h4 fw-bold mb-1">Uni course sections</h1>
        <p class="text-muted mb-0">Manage <code>dbo.CourseSections</code> — course offerings per academic year.</p>
    </div>
    <a class="btn btn-primary rounded-pill px-4" asp-action="Create">
        <i class="bi bi-plus-lg me-2"></i>Add course section
    </a>
</div>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-warning mb-3" role="alert">@error</div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mb-3" role="alert">@message</div>
}

<section class="portal-card">
    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-md-9">
            <label class="form-label" for="search">Search</label>
            <input type="search" class="form-control" id="search" name="search" value="@search"
                   placeholder="Academic year, course, or section name" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Academic year</th>
                    <th>Course</th>
                    <th>Section</th>
                    <th>Capacity</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="6" class="text-muted py-4 text-center">No course sections found.</td>
                </tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.CourseSectionId</td>
                    <td>@row.YearName</td>
                    <td class="fw-semibold">@row.CourseName</td>
                    <td>@(row.SectionName ?? "—")</td>
                    <td>@(row.Capacity?.ToString() ?? "—")</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-outline-success btn-sm" asp-action="Edit" asp-route-id="@row.CourseSectionId">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <form asp-action="Delete" asp-route-id="@row.CourseSectionId" method="post" class="d-inline"
                              onsubmit="return confirm('Delete this course section permanently?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
