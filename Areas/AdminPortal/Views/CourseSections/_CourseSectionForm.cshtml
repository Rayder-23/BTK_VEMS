@model CourseSectionFormPageViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<input type="hidden" asp-for="Form.CourseSectionId" />

<div class="row g-3">
    <div class="col-md-4">
        <label asp-for="Form.AcademicYearId" class="form-label"></label>
        <select asp-for="Form.AcademicYearId" class="form-select"
                asp-items="@(new SelectList(Model.Lookups.AcademicYears, nameof(StudentLookupItem.Id), nameof(StudentLookupItem.Name)))">
            <option value="">— Select academic year —</option>
        </select>
        <span asp-validation-for="Form.AcademicYearId" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Form.CourseId" class="form-label"></label>
        <select asp-for="Form.CourseId" class="form-select"
                asp-items="@(new SelectList(Model.Lookups.Courses, nameof(StudentLookupItem.Id), nameof(StudentLookupItem.Name)))">
            <option value="">— Select course —</option>
        </select>
        <span asp-validation-for="Form.CourseId" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Form.SectionName" class="form-label"></label>
        <input asp-for="Form.SectionName" class="form-control" maxlength="20" />
        <span asp-validation-for="Form.SectionName" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Form.Capacity" class="form-label"></label>
        <input asp-for="Form.Capacity" class="form-control" type="number" min="1" />
        <span asp-validation-for="Form.Capacity" class="text-danger small"></span>
    </div>
</div>
