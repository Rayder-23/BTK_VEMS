@model VEMS.Areas.AdminPortal.Models.Fee.ChallanDetailsPageModel
@{
    var h = Model.Header;
    ViewData["Title"] = $"Voucher {h.ChallanNo}";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Challan @h.ChallanNo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { font-family: Georgia, serif; padding: 2rem; max-width: 800px; margin: 0 auto; }
        .voucher-header { border-bottom: 2px solid #222; padding-bottom: 1rem; margin-bottom: 1.5rem; }
        @@media print { .no-print { display: none !important; } }
    </style>
</head>
<body>
    <div class="no-print mb-3 d-flex flex-wrap gap-2">
        <button type="button" class="btn btn-primary" onclick="window.print()">Print</button>
        <a class="btn btn-outline-secondary" href="/adminportal/fee/challans/details/@h.Uid">Back to details</a>
        <a class="btn btn-outline-secondary" href="/adminportal/fee/challans/print-voucher">Print another</a>
    </div>

    <div class="voucher-header text-center">
        <h1 class="h4 mb-0">VEMS — Fee challan voucher</h1>
        <p class="mb-0 text-muted">@h.ChallanNo</p>
    </div>

    <table class="table table-borderless table-sm">
        <tr><th style="width:38%">Student</th><td>@h.StudentName</td></tr>
        <tr><th>Registration</th><td>@h.RegistrationNo</td></tr>
        <tr><th>Term</th><td>@h.Semester @h.AcademicYear</td></tr>
        <tr><th>Due date</th><td>@h.DueDate.ToString("yyyy-MM-dd")</td></tr>
        <tr><th>Status</th><td>@h.DisplayStatus</td></tr>
        <tr><th>Net payable</th><td class="fs-5 fw-bold">@h.NetPayable.ToString("N2")</td></tr>
        <tr><th>Amount paid</th><td>@h.AmountPaid.ToString("N2")</td></tr>
        <tr><th>Balance</th><td>@((h.NetPayable - h.AmountPaid).ToString("N2"))</td></tr>
    </table>

    <h2 class="h6 mt-4 fw-bold border-bottom pb-2">Fee breakdown</h2>
    <table class="table table-sm">
        <thead>
            <tr><th>Fee head</th><th class="text-end">Amount</th><th class="text-end">Discount</th><th class="text-end">Late fine</th><th class="text-end">Net</th></tr>
        </thead>
        <tbody>
        @foreach (var line in Model.Lines)
        {
            <tr>
                <td>@line.FeeHeadName</td>
                <td class="text-end">@line.Amount.ToString("N2")</td>
                <td class="text-end">@line.DiscountAmount.ToString("N2")</td>
                <td class="text-end">@line.LateFine.ToString("N2")</td>
                <td class="text-end">@line.NetAmount.ToString("N2")</td>
            </tr>
        }
        </tbody>
    </table>

    <p class="text-muted small mt-5 text-center">Computer-generated challan voucher.</p>
</body>
</html>
