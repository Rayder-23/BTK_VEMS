@model IReadOnlyList<TimetableListItem>
@{
    ViewData["Title"] = "Timetable";
    var search = ViewData["Search"] as string;
    var message = TempData["StatusMessage"] as string;
}

<div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center mb-3">
    <div>
        <h1 class="h4 fw-bold mb-1">Timetable</h1>
        <p class="text-muted mb-0">Manage <code>dbo.Timetables</code> scheduled slots.</p>
    </div>
    <a class="btn btn-primary rounded-pill px-4" asp-action="Create">
        <i class="bi bi-plus-lg me-2"></i>Add slot
    </a>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mb-3" role="alert">@message</div>
}

<section class="portal-card">
    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-md-9">
            <label class="form-label" for="search">Search</label>
            <input type="search" class="form-control" id="search" name="search" value="@search"
                   placeholder="Day, period, course, teacher, room, or section" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Day</th>
                    <th>Period</th>
                    <th>Class section</th>
                    <th>Course section</th>
                    <th>Course</th>
                    <th>Teacher</th>
                    <th>Room</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="9" class="text-muted py-4 text-center">No timetable slots found.</td>
                </tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.TimetableId</td>
                    <td>@row.DayName</td>
                    <td>@row.PeriodDisplay</td>
                    <td>@(row.ClassSectionDisplay ?? "—")</td>
                    <td>@(row.CourseSectionDisplay ?? "—")</td>
                    <td class="fw-semibold">@row.CourseName</td>
                    <td>@row.TeacherName</td>
                    <td>@(row.RoomNo ?? "—")</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-outline-success btn-sm" asp-action="Edit" asp-route-id="@row.TimetableId">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <form asp-action="Delete" asp-route-id="@row.TimetableId" method="post" class="d-inline"
                              onsubmit="return confirm('Delete this timetable slot permanently?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
