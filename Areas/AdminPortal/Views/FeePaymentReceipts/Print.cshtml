@model VEMS.Areas.AdminPortal.Models.Fee.PaymentReceiptViewModel
@{
    ViewData["Title"] = $"Receipt {Model.ReceiptNo}";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Receipt @Model.ReceiptNo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { font-family: Georgia, serif; padding: 2rem; max-width: 720px; margin: 0 auto; }
        .receipt-header { border-bottom: 2px solid #222; padding-bottom: 1rem; margin-bottom: 1.5rem; }
        @@media print { .no-print { display: none; } }
    </style>
</head>
<body>
    <div class="no-print mb-3">
        <button type="button" class="btn btn-primary" onclick="window.print()">Print</button>
        <a class="btn btn-outline-secondary" href="/adminportal/fee/payment-receipts">Back</a>
    </div>

    <div class="receipt-header text-center">
        <h1 class="h4 mb-0">VEMS — Payment Receipt</h1>
        <p class="mb-0 text-muted">@Model.ReceiptNo</p>
    </div>

    <table class="table table-borderless table-sm">
        <tr><th style="width:40%">Issued</th><td>@Model.IssuedAt.ToLocalTime().ToString("f")</td></tr>
        <tr><th>Student</th><td>@Model.StudentName (@Model.RegistrationNo)</td></tr>
        <tr><th>Challan</th><td>@Model.ChallanNo</td></tr>
        <tr><th>Payment date</th><td>@Model.PaymentDate.ToString("yyyy-MM-dd")</td></tr>
        <tr><th>Mode</th><td>@Model.PaymentMode</td></tr>
        @if (!string.IsNullOrEmpty(Model.TransactionRef))
        {
            <tr><th>Reference</th><td>@Model.TransactionRef</td></tr>
        }
        <tr><th>Amount paid</th><td class="fs-5 fw-bold">@Model.AmountPaid.ToString("N2")</td></tr>
        <tr><th>Challan total paid</th><td>@Model.ChallanTotalPaid.ToString("N2") / @Model.ChallanNetPayable.ToString("N2")</td></tr>
    </table>

    <p class="text-muted small mt-5 text-center">Computer-generated receipt. Thank you.</p>
</body>
</html>
