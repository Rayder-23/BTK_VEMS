@model IReadOnlyList<StudentListItemViewModel>
@{
    ViewData["Title"] = "Students";
    var message = TempData["StatusMessage"] as string;
    var error = TempData["ErrorMessage"] as string;
}

<section class="portal-card page-summary-compact mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/students">Student Management</a></li>
            <li class="breadcrumb-item active" aria-current="page">@(ViewData["Title"] ?? "Students")</li>
        </ol>
    </nav>
    <div class="page-summary-head">
        <div class="page-summary-title-block">
            <span class="page-summary-title">Students</span>
            <span class="page-summary-meta">@Model.Count student(s) in <code>dbo.Students</code></span>
        </div>
        <a class="btn btn-sm btn-primary rounded-pill flex-shrink-0" asp-action="Create">
            <i class="bi bi-plus-lg me-1"></i>Add student
        </a>
    </div>
</section>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-warning py-2 mb-3" role="alert">@error</div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success py-2 mb-3" role="alert">@message</div>
}

<section class="portal-card">
    <div class="table-responsive">
        <table class="table table-sm admin-table admin-table-compact align-middle mb-0">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Registration</th>
                    <th scope="col">Name</th>
                    <th scope="col">Father</th>
                    <th scope="col">Program</th>
                    <th scope="col">Roll no.</th>
                    <th scope="col">Admission</th>
                    <th scope="col">Active</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="9" class="text-muted py-4 text-center">No students yet. Add one to get started.</td>
                </tr>
            }
            @foreach (var s in Model)
            {
                <tr>
                    <td>@s.Uid</td>
                    <td>@s.RegistrationNo</td>
                    <td>@s.DisplayName</td>
                    <td>@s.FatherName</td>
                    <td>@(s.ProgramName ?? "—")</td>
                    <td>@(s.RollNo ?? "—")</td>
                    <td>@s.AdmissionDate.ToString("yyyy-MM-dd")</td>
                    <td>@(s.IsActive ? "Yes" : "No")</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-outline-success btn-sm" asp-action="Edit" asp-route-id="@s.Uid"><i class="bi bi-pencil"></i> Edit</a>
                        <form asp-action="Delete" asp-route-id="@s.Uid" method="post" class="d-inline"
                              onsubmit="return confirm('Delete this student? Related records may block this.');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i> Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
