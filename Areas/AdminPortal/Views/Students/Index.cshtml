@model IReadOnlyList<StudentListItemViewModel>
@{
    ViewData["Title"] = "Students";
    var message = TempData["StatusMessage"] as string;
    var error = TempData["ErrorMessage"] as string;
}

<section class="module-page-header accent-blue">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Students</li>
        </ol>
    </nav>
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center">
        <div class="d-flex align-items-center gap-3">
            <span class="module-page-icon"><i class="bi bi-people-fill"></i></span>
            <div>
                <h1 class="h3 fw-bold mb-1">Students</h1>
                <p class="text-muted mb-0">CRUD for <code>dbo.Students</code> (see <code>Docs/db.txt</code>).</p>
            </div>
        </div>
        <a class="btn btn-primary rounded-pill px-4" asp-action="Create">
            <i class="bi bi-plus-lg me-2"></i>Add student
        </a>
    </div>
</section>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-warning mt-4 mb-0" role="alert">@error</div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mt-4 mb-0" role="alert">@message</div>
}

<section class="portal-card mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-3">
        <div>
            <h2 class="h5 fw-bold mb-1">Directory</h2>
            <p class="text-muted mb-0">@Model.Count student(s).</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Name</th>
                    <th scope="col">Email</th>
                    <th scope="col">Phone</th>
                    <th scope="col">Guardian</th>
                    <th scope="col">Grade</th>
                    <th scope="col">Status</th>
                    <th scope="col">Enrolled</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="9" class="text-muted py-4 text-center">No students yet. Add one to get started.</td>
                </tr>
            }
            @foreach (var s in Model)
            {
                <tr>
                    <td>@s.Uid</td>
                    <td>@s.FullName</td>
                    <td>@(s.Email ?? "—")</td>
                    <td>@(s.Phone ?? "—")</td>
                    <td>@s.GuardianName</td>
                    <td>@s.GradeLevel</td>
                    <td>@s.Status</td>
                    <td>@s.EnrolledDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">
                        <div class="d-inline-flex flex-wrap justify-content-end gap-1">
                            <a class="btn btn-outline-success btn-sm" asp-action="Edit" asp-route-id="@s.Uid"><i class="bi bi-pencil"></i> Edit</a>
                            <form asp-action="Delete" asp-route-id="@s.Uid" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this student? Related fee or challan rows may block this.');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i> Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
