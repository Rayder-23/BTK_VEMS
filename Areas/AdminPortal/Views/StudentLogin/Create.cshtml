@model StudentLoginFormViewModel
@{
    ViewData["Title"] = "Add Login";
}

<section class="module-page-header accent-indigo">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/students">Student Management</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Create Login</a></li>
            <li class="breadcrumb-item active" aria-current="page">Add</li>
        </ol>
    </nav>
    <h1 class="h3 fw-bold mb-0">Add student login</h1>
    <p class="text-muted mb-0 mt-2">Creates a row in <code>dbo.StudentsLogin</code>. Default password: <code>@StudentLoginFormViewModel.DefaultPassword</code>.</p>
</section>

<section class="portal-card mt-4">
    <form asp-action="Create" method="post" novalidate>
        @Html.AntiForgeryToken()
        <partial name="_StudentLoginForm" model="Model" />
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary" @(Model.AvailableStudents.Count == 0 ? "disabled" : null)>Save</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
}
