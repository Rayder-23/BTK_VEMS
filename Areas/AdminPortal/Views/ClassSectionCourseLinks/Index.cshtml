@model IReadOnlyList<ClassCourseListItem>
@{
    ViewData["Title"] = "Link class section courses";
    var search = ViewData["Search"] as string;
    var message = TempData["StatusMessage"] as string;
    var error = TempData["ErrorMessage"] as string;
}

<div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center mb-3">
    <div>
        <h1 class="h4 fw-bold mb-1">Link_ClassSectionCoursees</h1>
        <p class="text-muted mb-0">Manage <code>dbo.ClassSectionCourses</code> — class section + course links.</p>
    </div>
    <a class="btn btn-primary rounded-pill px-4" asp-action="Create">
        <i class="bi bi-plus-lg me-2"></i>Add link
    </a>
</div>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-warning mb-3" role="alert">@error</div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mb-3" role="alert">@message</div>
}

<section class="portal-card">
    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-md-9">
            <label class="form-label" for="search">Search</label>
            <input type="search" class="form-control" id="search" name="search" value="@search"
                   placeholder="Year, class, section, course" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Year</th>
                    <th>Class</th>
                    <th>Section</th>
                    <th>Course code</th>
                    <th>Course name</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-muted py-4 text-center">No class section course links found.</td>
                </tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.ClassSectionCourseId</td>
                    <td>@row.YearName</td>
                    <td>@row.ClassName</td>
                    <td>@row.SectionName</td>
                    <td>@(string.IsNullOrEmpty(row.CourseCode) ? "—" : row.CourseCode)</td>
                    <td>@row.CourseName</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-outline-success btn-sm" asp-action="Edit" asp-route-id="@row.ClassSectionCourseId">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <form asp-action="Delete" asp-route-id="@row.ClassSectionCourseId" method="post" class="d-inline"
                              onsubmit="return confirm('Delete this class section course link permanently?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
