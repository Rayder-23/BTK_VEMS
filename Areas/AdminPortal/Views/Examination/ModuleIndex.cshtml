@model VEMS.Areas.AdminPortal.Models.Examination.ExaminationListPageViewModel

<section class="module-page-header accent-teal">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center">
        <h1 class="h3 fw-bold mb-0">@Model.PageTitle</h1>
        <span class="text-muted small">Top 500 rows — connect create/edit workflows next.</span>
    </div>
</section>

<section class="portal-card mt-4">
    @if (Model.Rows.Count == 0)
    {
        <p class="text-muted mb-0">No data yet. Seed reference rows or capture marks to see listings here.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table admin-table align-middle">
                <thead>
                    <tr>
                        @foreach (var h in Model.Headers)
                        {
                            <th scope="col">@h</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Rows)
                    {
                        <tr>
                            @foreach (var cell in row)
                            {
                                <td>@cell</td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
