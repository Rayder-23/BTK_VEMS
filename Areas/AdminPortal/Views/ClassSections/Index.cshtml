@model IReadOnlyList<ClassSectionListItem>
@{
    ViewData["Title"] = "Link class sections";
    var search = ViewData["Search"] as string;
    var message = TempData["StatusMessage"] as string;
    var error = TempData["ErrorMessage"] as string;
}

<div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center mb-3">
    <div>
        <h1 class="h4 fw-bold mb-1">Link class sections</h1>
        <p class="text-muted mb-0">Manage <code>dbo.ClassSections</code> — class + section per academic year.</p>
    </div>
    <a class="btn btn-primary rounded-pill px-4" asp-action="Create">
        <i class="bi bi-plus-lg me-2"></i>Add link
    </a>
</div>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-warning mb-3" role="alert">@error</div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mb-3" role="alert">@message</div>
}

<section class="portal-card">
    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-md-9">
            <label class="form-label" for="search">Search</label>
            <input type="search" class="form-control" id="search" name="search" value="@search"
                   placeholder="Academic year, class, or section" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Academic year</th>
                    <th>Class</th>
                    <th>Section</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="5" class="text-muted py-4 text-center">No class section links found.</td>
                </tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.ClassSectionId</td>
                    <td>@row.YearName</td>
                    <td class="fw-semibold">@row.ClassName</td>
                    <td>@row.SectionName</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-outline-success btn-sm" asp-action="Edit" asp-route-id="@row.ClassSectionId">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <form asp-action="Delete" asp-route-id="@row.ClassSectionId" method="post" class="d-inline"
                              onsubmit="return confirm('Delete this class section link permanently?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
