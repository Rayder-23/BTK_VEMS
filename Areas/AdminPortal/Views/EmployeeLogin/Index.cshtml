@model IReadOnlyList<EmployeeLoginListItemViewModel>
@{
    ViewData["Title"] = "Employee Logins";
    var message = TempData["StatusMessage"] as string;
}

<section class="module-page-header accent-indigo">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/hr">HR</a></li>
            <li class="breadcrumb-item active" aria-current="page">Create Login</li>
        </ol>
    </nav>
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center">
        <div class="d-flex align-items-center gap-3">
            <span class="module-page-icon"><i class="bi bi-key-fill"></i></span>
            <div>
                <h1 class="h3 fw-bold mb-1">Employee logins</h1>
                <p class="text-muted mb-0">Portal accounts in <code>dbo.EmployeeLogin</code>. New accounts default to password <code>@EmployeeLoginFormViewModel.DefaultPassword</code>.</p>
            </div>
        </div>
        <a class="btn btn-primary rounded-pill px-4" asp-action="Create">
            <i class="bi bi-plus-lg me-2"></i>Add login
        </a>
    </div>
</section>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mt-4 mb-0" role="alert">@message</div>
}

<section class="portal-card mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-3">
        <div>
            <h2 class="h5 fw-bold mb-1">All logins</h2>
            <p class="text-muted mb-0">@Model.Count account(s).</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Username</th>
                    <th scope="col">Employee</th>
                    <th scope="col">Employee ID</th>
                    <th scope="col">Role</th>
                    <th scope="col">Status</th>
                    <th scope="col">Created</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="8" class="text-muted py-4 text-center">No employee logins yet.</td>
                </tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.Uid</td>
                    <td>@row.Username</td>
                    <td>@row.EmployeeName</td>
                    <td>@row.EmployeeCode</td>
                    <td>@row.Role</td>
                    <td>@row.Status</td>
                    <td>@row.CreatedOn.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end">
                        <a class="btn btn-outline-success btn-sm" asp-action="Edit" asp-route-id="@row.Uid">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
