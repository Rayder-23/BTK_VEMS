@model IReadOnlyList<AcademicYearListItem>
@{
    ViewData["Title"] = "Academic years";
    var search = ViewData["Search"] as string;
    var showInactive = ViewData["ShowInactive"] as bool? ?? false;
    var message = TempData["StatusMessage"] as string;
    var error = TempData["ErrorMessage"] as string;
}

<div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center mb-3">
    <div>
        <h1 class="h4 fw-bold mb-1">Academic years</h1>
        <p class="text-muted mb-0">Manage <code>dbo.AcademicYears</code> records.</p>
    </div>
    <a class="btn btn-primary rounded-pill px-4" asp-action="Create">
        <i class="bi bi-plus-lg me-2"></i>Add academic year
    </a>
</div>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-warning mb-3" role="alert">@error</div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mb-3" role="alert">@message</div>
}

<section class="portal-card">
    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-md-6">
            <label class="form-label" for="search">Search</label>
            <input type="search" class="form-control" id="search" name="search" value="@search" placeholder="Year name" />
        </div>
        <div class="col-md-3">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="showInactive" value="true" id="showInactive" @(showInactive ? "checked" : "") />
                <label class="form-check-label" for="showInactive">Show inactive</label>
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Year name</th>
                    <th>Start date</th>
                    <th>End date</th>
                    <th>Current</th>
                    <th>Active</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="8" class="text-muted py-4 text-center">No academic years found.</td>
                </tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.AcademicYearId</td>
                    <td class="fw-semibold">@row.YearName</td>
                    <td>@(row.StartDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                    <td>@(row.EndDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                    <td>@(row.IsCurrent ? "Yes" : "No")</td>
                    <td>@(row.IsActive ? "Yes" : "No")</td>
                    <td>@row.CreatedOn.ToString("yyyy-MM-dd")</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-outline-success btn-sm" asp-action="Edit" asp-route-id="@row.AcademicYearId">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        @if (row.IsActive)
                        {
                            <form asp-action="Deactivate" asp-route-id="@row.AcademicYearId" method="post" class="d-inline"
                                  onsubmit="return confirm('Deactivate this academic year?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-warning btn-sm">Deactivate</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="Activate" asp-route-id="@row.AcademicYearId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-success btn-sm">Activate</button>
                            </form>
                        }
                        <form asp-action="Delete" asp-route-id="@row.AcademicYearId" method="post" class="d-inline"
                              onsubmit="return confirm('Delete this academic year permanently?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
