@model AcademicYearFormModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row g-3">
    @if (Model.AcademicYearId > 0)
    {
        <input type="hidden" asp-for="AcademicYearId" />
    }
    <div class="col-12 col-lg-6">
        <label asp-for="YearName" class="form-label"></label>
        <input asp-for="YearName" class="form-control" maxlength="20" placeholder="e.g. 2026-2027" />
        <span asp-validation-for="YearName" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-3">
        <label asp-for="StartDate" class="form-label"></label>
        <input asp-for="StartDate" class="form-control" type="date" />
        <span asp-validation-for="StartDate" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-3">
        <label asp-for="EndDate" class="form-label"></label>
        <input asp-for="EndDate" class="form-control" type="date" />
        <span asp-validation-for="EndDate" class="text-danger small"></span>
    </div>
    <div class="col-12 col-lg-6">
        <div class="form-check form-switch">
            <input asp-for="IsCurrent" class="form-check-input" type="checkbox" role="switch" />
            <label asp-for="IsCurrent" class="form-check-label"></label>
        </div>
        <div class="form-text">Only one academic year should be marked as current.</div>
    </div>
    <div class="col-12 col-lg-6">
        <div class="form-check form-switch">
            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
            <label asp-for="IsActive" class="form-check-label"></label>
        </div>
    </div>
    @if (Model.CreatedOn.HasValue)
    {
        <div class="col-12 col-lg-6">
            <label asp-for="CreatedOn" class="form-label"></label>
            <input asp-for="CreatedOn" class="form-control" readonly />
        </div>
    }
</div>
