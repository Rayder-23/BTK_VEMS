@model TeacherAssignmentFormPageViewModel
@{
    ViewData["Title"] = "Edit teacher assignment";
}

<section class="portal-card page-summary-compact mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/teachers">Teachers</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Link_TeacherAssignment</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit</li>
        </ol>
    </nav>
    <div class="page-summary-title-block">
        <span class="page-summary-title">Edit teacher assignment</span>
        <span class="page-summary-meta">Update row in <code>dbo.TeacherAssignments</code></span>
    </div>
</section>

<section class="portal-card">
    <form asp-action="Edit" asp-route-id="@Model.Form.TeacherAssignmentId" method="post" novalidate>
        @Html.AntiForgeryToken()
        <partial name="_TeacherAssignmentForm" model="Model" />
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
}
