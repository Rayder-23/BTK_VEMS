@model IReadOnlyList<TeacherAssignmentListItem>
@{
    ViewData["Title"] = "Link teacher assignment";
    var search = ViewData["Search"] as string;
    var message = TempData["StatusMessage"] as string;
    var error = TempData["ErrorMessage"] as string;
}

<section class="portal-card page-summary-compact mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/teachers">Teachers</a></li>
            <li class="breadcrumb-item active" aria-current="page">Link_TeacherAssignment</li>
        </ol>
    </nav>
    <div class="page-summary-head">
        <div class="page-summary-title-block">
            <span class="page-summary-title">Link_TeacherAssignment</span>
            <span class="page-summary-meta">Teacher assignments in <code>dbo.TeacherAssignments</code></span>
        </div>
        <a class="btn btn-sm btn-primary rounded-pill flex-shrink-0" asp-action="Create">
            <i class="bi bi-plus-lg me-1"></i>Add assignment
        </a>
    </div>
</section>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-warning mb-3" role="alert">@error</div>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mb-3" role="alert">@message</div>
}

<section class="portal-card">
    <form method="get" class="row g-2 align-items-end mb-3" asp-action="Index">
        <div class="col-md-9">
            <label class="form-label" for="search">Search</label>
            <input type="search" class="form-control form-control-sm" id="search" name="search" value="@search"
                   placeholder="Year, teacher, course, class section" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-sm admin-table admin-table-compact align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Year</th>
                    <th>Teacher</th>
                    <th>Course code</th>
                    <th>Course name</th>
                    <th>Class section</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-muted py-4 text-center">No teacher assignments found.</td>
                </tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.TeacherAssignmentId</td>
                    <td>@row.YearName</td>
                    <td class="fw-semibold">@row.TeacherName</td>
                    <td>@(string.IsNullOrEmpty(row.CourseCode) ? "—" : row.CourseCode)</td>
                    <td>@row.CourseName</td>
                    <td>@(string.IsNullOrEmpty(row.ClassSectionDisplay) ? "—" : row.ClassSectionDisplay)</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-outline-success btn-sm" asp-action="Edit" asp-route-id="@row.TeacherAssignmentId">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <form asp-action="Delete" asp-route-id="@row.TeacherAssignmentId" method="post" class="d-inline"
                              onsubmit="return confirm('Delete this teacher assignment permanently?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
