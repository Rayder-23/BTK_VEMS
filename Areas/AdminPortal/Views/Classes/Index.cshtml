@model IReadOnlyList<VEMS.Areas.TeacherPortal.Models.ClassListItem>
@{
    ViewData["Title"] = "Classes";
    var search = ViewData["Search"] as string;
    var showInactive = ViewData["ShowInactive"] as bool? ?? false;
    var message = TempData["StatusMessage"] as string;
    var error = TempData["ErrorMessage"] as string;
}

<section class="module-page-header accent-purple">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/settings">Settings</a></li>
            <li class="breadcrumb-item active" aria-current="page">Classes</li>
        </ol>
    </nav>
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center">
        <div class="d-flex align-items-center gap-3">
            <span class="module-page-icon"><i class="bi bi-door-open-fill"></i></span>
            <div>
                <h1 class="h3 fw-bold mb-1">Classes</h1>
                <p class="text-muted mb-0">Teaching classes in <code>dbo.Classes</code>.</p>
            </div>
        </div>
        <a class="btn btn-primary rounded-pill px-4" asp-action="Create">
            <i class="bi bi-plus-lg me-2"></i>Add class
        </a>
    </div>
</section>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mt-4 mb-0" role="alert">@message</div>
}
@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger mt-4 mb-0" role="alert">@error</div>
}

<section class="portal-card mt-4">
    <form method="get" class="row g-2 align-items-end mb-3" asp-action="Index">
        <div class="col-md-6">
            <label class="form-label" for="search">Search</label>
            <input type="search" class="form-control" id="search" name="search" value="@search"
                   placeholder="Name or code" />
        </div>
        <div class="col-md-3">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="showInactive" value="true" id="showInactive"
                       @(showInactive ? "checked" : "") />
                <label class="form-check-label" for="showInactive">Show inactive</label>
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-sm admin-table admin-table-compact align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Code</th>
                    <th>Class name</th>
                    <th>Sort</th>
                    <th>Active</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="6" class="text-center text-muted py-4">No classes found.</td></tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.ClassId</td>
                    <td class="fw-semibold">@(string.IsNullOrWhiteSpace(row.ClassCode) ? "—" : row.ClassCode)</td>
                    <td>@row.ClassName</td>
                    <td>@(row.SortOrder?.ToString() ?? "—")</td>
                    <td>@(row.IsActive ? "Yes" : "No")</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@row.ClassId">Edit</a>
                        @if (row.IsActive)
                        {
                            <form method="post" asp-action="Deactivate" asp-route-id="@row.ClassId" class="d-inline"
                                  onsubmit="return confirm('Deactivate this class?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-warning">Deactivate</button>
                            </form>
                        }
                        else
                        {
                            <form method="post" asp-action="Activate" asp-route-id="@row.ClassId" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-success">Activate</button>
                            </form>
                        }
                        <form method="post" asp-action="Delete" asp-route-id="@row.ClassId" class="d-inline"
                              onsubmit="return confirm('Permanently delete this class?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
