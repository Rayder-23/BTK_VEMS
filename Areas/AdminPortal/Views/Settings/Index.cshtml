@{
    ViewData["Title"] = "Dashboard";
    ViewData["PageTitle"] = "Settings · Dashboard";
}

<div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center mb-3">
    <div>
        <h1 class="h4 fw-bold mb-1">Settings dashboard</h1>
        <p class="text-muted mb-0">Manage academic structure, links, timetable data, and system configuration keys.</p>
    </div>
</div>

<section class="portal-card">
    <h2 class="h5 fw-bold mb-3">Quick links</h2>
    <div class="row g-3">
        <div class="col-md-6 col-lg-4">
            <a class="btn btn-outline-primary w-100" href="/adminportal/settings/configurations">
                <i class="bi bi-sliders me-2"></i>Configurations
            </a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a class="btn btn-outline-primary w-100" href="/adminportal/settings/academic-years">
                <i class="bi bi-calendar3 me-2"></i>Academic years
            </a>
        </div>
        <div class="col-md-6 col-lg-4">
            <a class="btn btn-outline-primary w-100" href="/adminportal/settings/timetables">
                <i class="bi bi-calendar-week me-2"></i>Timetable
            </a>
        </div>
    </div>
</section>
