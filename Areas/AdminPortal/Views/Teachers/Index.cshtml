@model IReadOnlyList<TeacherListItemViewModel>
@{
    ViewData["Title"] = "Teachers";
    var search = ViewData["Search"] as string;
    var showInactive = ViewData["ShowInactive"] as bool? ?? false;
    var message = TempData["StatusMessage"] as string;
}

<section class="portal-card page-summary-compact mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/teachers">Teachers</a></li>
            <li class="breadcrumb-item active" aria-current="page">All Teachers</li>
        </ol>
    </nav>
    <div class="page-summary-head">
        <div class="page-summary-title-block">
            <span class="page-summary-title">All Teachers</span>
            <span class="page-summary-meta">Faculty records in <code>dbo.Teachers</code></span>
        </div>
        <a class="btn btn-sm btn-primary rounded-pill flex-shrink-0" asp-action="Create">
            <i class="bi bi-plus-lg me-1"></i>Add teacher
        </a>
    </div>
</section>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mb-3" role="alert">@message</div>
}

<section class="portal-card">
    <form method="get" class="row g-2 align-items-end mb-2">
        <div class="col-md-6">
            <label class="form-label" for="search">Search</label>
            <input type="search" class="form-control form-control-sm" id="search" name="search" value="@search"
                   placeholder="Employee no., name, email, mobile" />
        </div>
        <div class="col-md-3">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="showInactive" value="true" id="showInactive"
                       @(showInactive ? "checked" : "") />
                <label class="form-check-label" for="showInactive">Show inactive</label>
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-sm admin-table admin-table-compact align-middle mb-0">
            <thead>
                <tr>
                    <th>Employee no.</th>
                    <th>Name</th>
                    <th>Mobile</th>
                    <th>Email</th>
                    <th>Active</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="6" class="text-center text-muted py-4">No teachers found.</td></tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td class="fw-semibold">@(string.IsNullOrWhiteSpace(row.EmployeeNo) ? "—" : row.EmployeeNo)</td>
                    <td>@row.TeacherName</td>
                    <td>@(row.MobileNo ?? "—")</td>
                    <td>@(row.Email ?? "—")</td>
                    <td>@(row.IsActive ? "Yes" : "No")</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Assignments" asp-route-teacherId="@row.TeacherId">
                            Assignments
                        </a>
                        <a class="btn btn-sm btn-outline-success" asp-action="Edit" asp-route-id="@row.TeacherId">Edit</a>
                        @if (row.IsActive)
                        {
                            <form asp-action="Delete" asp-route-id="@row.TeacherId" method="post" class="d-inline"
                                  onsubmit="return confirm('Deactivate this teacher?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Deactivate</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
