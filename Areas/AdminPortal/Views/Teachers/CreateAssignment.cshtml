@model TeacherCourseAssignmentFormPageViewModel
@{
    ViewData["Title"] = "Assign class and course";
}

<section class="module-page-header accent-purple">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Teachers</a></li>
            <li class="breadcrumb-item">
                <a asp-action="Assignments" asp-route-teacherId="@Model.Teacher.TeacherId">Assignments</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Add</li>
        </ol>
    </nav>
    <h1 class="h3 fw-bold mb-0">Assign class and course</h1>
    <p class="text-muted mb-0 mt-2">
        Teacher: <strong>@Model.Teacher.FullName</strong> (@Model.Teacher.EmployeeCode)
    </p>
</section>

<section class="portal-card mt-4">
    <form asp-action="CreateAssignment" asp-route-teacherId="@Model.Teacher.TeacherId" method="post" novalidate>
        @Html.AntiForgeryToken()
        <partial name="_AssignmentForm" model="Model" />
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Save assignment</button>
            <a class="btn btn-outline-secondary"
               asp-action="Assignments" asp-route-teacherId="@Model.Teacher.TeacherId">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
}
