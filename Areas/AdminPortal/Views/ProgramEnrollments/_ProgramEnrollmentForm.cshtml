@model ProgramEnrollmentFormPageViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<input type="hidden" asp-for="Form.Uid" />

<div class="student-mgmt-admin-form-grid">
    <div class="row student-mgmt-admin-form-row g-1 align-items-center">
        <label class="col-6 col-lg-3 student-mgmt-admin-form-label" asp-for="Form.StudentId"></label>
        <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
            <select asp-for="Form.StudentId" class="form-select form-select-sm"
                    asp-items="@(new SelectList(Model.Lookups.Students, nameof(StudentLookupItem.Id), nameof(StudentLookupItem.Name)))">
                <option value="">— Select student —</option>
            </select>
            <span asp-validation-for="Form.StudentId" class="text-danger small"></span>
        </div>
        <label class="col-6 col-lg-3 student-mgmt-admin-form-label" asp-for="Form.ProgramId"></label>
        <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
            <select asp-for="Form.ProgramId" class="form-select form-select-sm" id="programSelect"
                    asp-items="@(new SelectList(Model.Lookups.Programs, nameof(StudentLookupItem.Id), nameof(StudentLookupItem.Name)))">
                <option value="">— Select program —</option>
            </select>
            <span asp-validation-for="Form.ProgramId" class="text-danger small"></span>
        </div>
    </div>
    <div class="row student-mgmt-admin-form-row g-1 align-items-center">
        <label class="col-6 col-lg-3 student-mgmt-admin-form-label" asp-for="Form.AcademicYear"></label>
        <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
            <input asp-for="Form.AcademicYear" class="form-control form-control-sm" type="number" min="1990" max="2100" />
            <span asp-validation-for="Form.AcademicYear" class="text-danger small"></span>
        </div>
        <label class="col-6 col-lg-3 student-mgmt-admin-form-label" asp-for="Form.GradeOrSemester"></label>
        <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
            <input asp-for="Form.GradeOrSemester" class="form-control form-control-sm" type="number" min="1" max="255" />
            <span asp-validation-for="Form.GradeOrSemester" class="text-danger small"></span>
        </div>
    </div>
    <div class="row student-mgmt-admin-form-row g-1 align-items-center">
        <label class="col-6 col-lg-3 student-mgmt-admin-form-label" asp-for="Form.SectionId"></label>
        <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
            <select asp-for="Form.SectionId" class="form-select form-select-sm" id="sectionSelect"
                    asp-items="@(new SelectList(Model.Lookups.Sections, nameof(StudentLookupItem.Id), nameof(StudentLookupItem.Name)))">
                <option value="">— Select section —</option>
            </select>
            <span asp-validation-for="Form.SectionId" class="text-danger small"></span>
        </div>
        <label class="col-6 col-lg-3 student-mgmt-admin-form-label" asp-for="Form.RollNo"></label>
        <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
            <input asp-for="Form.RollNo" class="form-control form-control-sm" />
            <span asp-validation-for="Form.RollNo" class="text-danger small"></span>
        </div>
    </div>
    <div class="row student-mgmt-admin-form-row g-1 align-items-center">
        <label class="col-6 col-lg-3 student-mgmt-admin-form-label" asp-for="Form.EnrollmentDate"></label>
        <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
            <input asp-for="Form.EnrollmentDate" class="form-control form-control-sm" type="date" />
            <span asp-validation-for="Form.EnrollmentDate" class="text-danger small"></span>
        </div>
        <label class="col-6 col-lg-3 student-mgmt-admin-form-label" asp-for="Form.CompletionDate"></label>
        <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
            <input asp-for="Form.CompletionDate" class="form-control form-control-sm" type="date" />
            <span asp-validation-for="Form.CompletionDate" class="text-danger small"></span>
        </div>
    </div>
    <div class="row student-mgmt-admin-form-row g-1 align-items-center">
        <label class="col-6 col-lg-3 student-mgmt-admin-form-label" asp-for="Form.EnrollmentStatus"></label>
        <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
            <select asp-for="Form.EnrollmentStatus" class="form-select form-select-sm"
                    asp-items="@(new SelectList(Model.Lookups.EnrollmentStatuses))"></select>
            <span asp-validation-for="Form.EnrollmentStatus" class="text-danger small"></span>
        </div>
        <label class="col-6 col-lg-3 student-mgmt-admin-form-label" asp-for="Form.FeeStatus"></label>
        <div class="col-6 col-lg-3 student-mgmt-admin-form-field">
            <select asp-for="Form.FeeStatus" class="form-select form-select-sm"
                    asp-items="@(new SelectList(Model.Lookups.FeeStatuses))"></select>
            <span asp-validation-for="Form.FeeStatus" class="text-danger small"></span>
        </div>
    </div>
    <div class="row student-mgmt-admin-form-row g-1 align-items-start">
        <label class="col-12 col-lg-3 student-mgmt-admin-form-label" asp-for="Form.Remarks"></label>
        <div class="col-12 col-lg-9 student-mgmt-admin-form-field">
            <textarea asp-for="Form.Remarks" class="form-control form-control-sm" rows="2"></textarea>
            <span asp-validation-for="Form.Remarks" class="text-danger small"></span>
        </div>
    </div>
</div>
