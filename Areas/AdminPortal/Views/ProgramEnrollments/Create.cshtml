@model ProgramEnrollmentFormPageViewModel
@{
    ViewData["Title"] = "Add program enrollment";
}

<section class="module-page-header accent-cyan">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-3">
            <li class="breadcrumb-item"><a href="/adminportal">Admin</a></li>
            <li class="breadcrumb-item"><a href="/adminportal/students">Student Management</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Program Enrollments</a></li>
            <li class="breadcrumb-item active" aria-current="page">Add</li>
        </ol>
    </nav>
    <h1 class="h3 fw-bold mb-0">Add program enrollment</h1>
    <p class="text-muted mb-0 mt-2">Creates a row in <code>dbo.StudentEnrollments</code>.</p>
</section>

<section class="portal-card mt-4">
    <form asp-action="Create" method="post" novalidate>
        @Html.AntiForgeryToken()
        <partial name="_ProgramEnrollmentForm" model="Model" />
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const programSelect = document.getElementById('programSelect');
            const classSelect = document.getElementById('classSelect');
            if (!programSelect || !classSelect) return;

            async function loadClasses(programId, selectedId) {
                const current = selectedId || classSelect.value;
                classSelect.innerHTML = '<option value="">— Select class —</option>';
                if (!programId) return;

                const response = await fetch(`/adminportal/students/program-enrollments/lookups?programId=${programId}`);
                if (!response.ok) return;

                const items = await response.json();
                items.forEach((item) => {
                    const option = document.createElement('option');
                    option.value = item.id;
                    option.textContent = item.name;
                    if (current && Number(current) === Number(item.id)) {
                        option.selected = true;
                    }
                    classSelect.appendChild(option);
                });
            }

            programSelect.addEventListener('change', () => {
                loadClasses(programSelect.value, null);
            });

            if (programSelect.value) {
                loadClasses(programSelect.value, classSelect.value);
            }
        })();
    </script>
}
