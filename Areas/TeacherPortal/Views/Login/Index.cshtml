@model VEMS.Areas.TeacherPortal.Models.TeacherLoginViewModel

@{
    Layout = null;
    ViewData["Title"] = "Teacher Login";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Virtual Education Management System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/portals/teacher-login.css" asp-append-version="true" />
</head>
<body class="teacher-login-page">
    <main class="login-shell">
        <section class="login-hero d-none d-lg-flex">
            <div class="login-hero-content">
                <span class="login-badge"><i class="bi bi-easel-fill me-2"></i>Teacher Portal</span>
                <h1>Welcome back to your teaching workspace.</h1>
                <p>
                    Manage classes, attendance, results, and student advising through the Virtual Education Management System.
                </p>
                <div class="login-feature-list">
                    <span><i class="bi bi-check-circle-fill"></i> Secure staff access</span>
                    <span><i class="bi bi-check-circle-fill"></i> Teacher role required</span>
                    <span><i class="bi bi-check-circle-fill"></i> Dashboard after login</span>
                </div>
            </div>
        </section>

        <section class="login-card-wrap">
            <div class="login-card">
                <div class="text-center mb-4">
                    <div class="login-logo mx-auto mb-3">
                        <i class="bi bi-person-workspace"></i>
                    </div>
                    <h2 class="fw-bold mb-1">Teacher Login</h2>
                    <p class="text-muted mb-0">Sign in with your employee account.</p>
                </div>

                <form asp-area="TeacherPortal" asp-controller="Login" asp-action="Index" asp-route-returnUrl="@returnUrl" method="post" novalidate>
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label fw-semibold"></label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input asp-for="Username" class="form-control" autocomplete="username" placeholder="Enter username" autofocus />
                        </div>
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
                            <input asp-for="Password" class="form-control" autocomplete="current-password" placeholder="Enter password" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label"></label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Login
                    </button>
                </form>
            </div>
        </section>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
</body>
</html>
