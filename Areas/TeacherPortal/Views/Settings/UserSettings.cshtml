@{
    ViewData["Title"] = "User Settings";
}

<div class="portal-card mb-3">
    <h1 class="h5 fw-bold mb-1">User settings</h1>
    <p class="text-muted mb-0">Manage your account preferences and security options.</p>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="portal-card h-100">
            <h2 class="h6 fw-bold mb-2"><i class="bi bi-shield-lock me-2 text-primary"></i>Security</h2>
            <p class="text-muted small mb-3">Update your portal password regularly to keep your account secure.</p>
            <a class="btn btn-outline-primary btn-sm"
               asp-area="TeacherPortal" asp-controller="Settings" asp-action="ChangePassword">
                <i class="bi bi-key me-1"></i>Change password
            </a>
        </div>
    </div>
    <div class="col-md-6">
        <div class="portal-card h-100">
            <h2 class="h6 fw-bold mb-2"><i class="bi bi-person-vcard me-2 text-primary"></i>Profile</h2>
            <p class="text-muted small mb-3">Review your employee profile and contact information.</p>
            <a class="btn btn-outline-primary btn-sm"
               asp-area="TeacherPortal" asp-controller="Profile" asp-action="Index">
                <i class="bi bi-person me-1"></i>View profile
            </a>
        </div>
    </div>
</div>
