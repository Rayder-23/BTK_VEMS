@model TeacherChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    var passwordMessage = TempData["PasswordMessage"] as string;
}

<div class="portal-card">
    <h1 class="h5 fw-bold mb-1">Change password</h1>
    <p class="text-muted mb-3">Enter your current password, then your new password twice. Both new fields must match.</p>

    @if (!string.IsNullOrEmpty(passwordMessage))
    {
        <div class="alert alert-success" role="alert">@passwordMessage</div>
    }

    <form asp-action="ChangePassword" method="post" novalidate>
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-12 col-md-4">
                <label asp-for="OldPassword" class="form-label"></label>
                <input asp-for="OldPassword" class="form-control" autocomplete="current-password" />
                <span asp-validation-for="OldPassword" class="text-danger small"></span>
            </div>
            <div class="col-12 col-md-4">
                <label asp-for="NewPassword" class="form-label"></label>
                <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>
            <div class="col-12 col-md-4">
                <label asp-for="ConfirmNewPassword" class="form-label"></label>
                <input asp-for="ConfirmNewPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
            </div>
        </div>

        <button type="submit" class="btn btn-primary mt-3">
            <i class="bi bi-shield-lock me-2"></i>Update password
        </button>
    </form>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
}
