@{
    ViewData["Title"] = "Teacher Portal";
}

<div class="container py-5">
    <header class="border-bottom pb-4 mb-4">
        <p class="text-primary fw-semibold small text-uppercase mb-2">Faculty</p>
        <h1 class="display-6 fw-bold">Welcome to the Teacher Portal</h1>
        <p class="lead text-muted mb-0">
            Manage sections, assessments, gradebooks, and class communications from this workspace.
        </p>
    </header>
    <div class="row g-4">
        <div class="col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h2 class="h5 fw-semibold mb-2"><i class="bi bi-easel2-fill text-primary me-2"></i>Classes</h2>
                    <p class="small text-muted mb-0">Open rosters, attendance, and session tools.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h2 class="h5 fw-semibold mb-2"><i class="bi bi-clipboard-data-fill text-primary me-2"></i>Grading</h2>
                    <p class="small text-muted mb-0">Rubrics, submissions, and feedback workflows.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h2 class="h5 fw-semibold mb-2"><i class="bi bi-people-fill text-primary me-2"></i>Students</h2>
                    <p class="small text-muted mb-0">Insights and outreach for your cohorts.</p>
                </div>
            </div>
        </div>
    </div>
</div>
