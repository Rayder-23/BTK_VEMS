@model IReadOnlyList<VEMS.Areas.AdminPortal.Models.CourseListItem>
@{
    ViewData["Title"] = "My Courses";
    var search = ViewData["Search"] as string;
    var showInactive = ViewData["ShowInactive"] as bool? ?? false;
    var noTeacherProfile = ViewData["NoTeacherProfile"] as bool? == true;
}

<div class="portal-card mb-3">
    <div>
        <h1 class="h5 fw-bold mb-1">My courses</h1>
        <p class="text-muted mb-0 small">Read-only list of courses assigned to you through course assignments.</p>
    </div>
</div>

@if (noTeacherProfile)
{
    <div class="alert alert-warning" role="alert">
        No teacher profile is linked to your account. Ask an administrator to create a teacher record and assign courses.
    </div>
}

<div class="portal-card">
    <form method="get" class="row g-2 align-items-end mb-3"
          asp-area="TeacherPortal" asp-controller="AcademicManagement" asp-action="Courses">
        <div class="col-md-6">
            <label class="form-label" for="search">Search</label>
            <input type="search" class="form-control" id="search" name="search" value="@search"
                   placeholder="Code, title, program" />
        </div>
        <div class="col-md-3">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="showInactive" value="true" id="showInactive"
                       @(showInactive ? "checked" : "") />
                <label class="form-check-label" for="showInactive">Show inactive</label>
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Title</th>
                    <th>Program</th>
                    <th>Credits</th>
                    <th>Type</th>
                    <th>Level</th>
                    <th>Active</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="7" class="text-center text-muted py-4">No assigned courses found.</td></tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td class="fw-semibold">@row.CourseCode</td>
                    <td>@row.CourseTitle</td>
                    <td>@row.ProgramName</td>
                    <td>@row.CreditHours</td>
                    <td>@row.CourseType</td>
                    <td>@row.CourseLevel</td>
                    <td>@(row.IsActive ? "Yes" : "No")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
