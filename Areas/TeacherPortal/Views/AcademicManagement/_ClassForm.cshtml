@model ClassFormPageViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row g-3">
    <input type="hidden" asp-for="Form.ClassId" />
    <div class="col-md-6">
        <label asp-for="Form.ClassName" class="form-label"></label>
        <input asp-for="Form.ClassName" class="form-control" maxlength="100" />
        <span asp-validation-for="Form.ClassName" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Form.ClassCode" class="form-label"></label>
        <input asp-for="Form.ClassCode" class="form-control" maxlength="20" />
        <span asp-validation-for="Form.ClassCode" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Form.SortOrder" class="form-label"></label>
        <input asp-for="Form.SortOrder" class="form-control" type="number" />
        <span asp-validation-for="Form.SortOrder" class="text-danger small"></span>
    </div>
    <div class="col-md-6 d-flex align-items-end">
        <div class="form-check mb-2">
            <input asp-for="Form.IsActive" class="form-check-input" />
            <label asp-for="Form.IsActive" class="form-check-label"></label>
        </div>
    </div>
</div>
