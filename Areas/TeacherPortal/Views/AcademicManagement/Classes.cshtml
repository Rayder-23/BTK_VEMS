@model IReadOnlyList<ClassListItem>
@{
    ViewData["Title"] = "Classes";
    var search = ViewData["Search"] as string;
    var showInactive = ViewData["ShowInactive"] as bool? ?? false;
    var message = TempData["StatusMessage"] as string;
}

<div class="portal-card mb-3">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
        <div>
            <h1 class="h5 fw-bold mb-1">Classes</h1>
            <p class="text-muted mb-0 small">Manage teaching classes in <code>dbo.Classes</code>.</p>
        </div>
        <a class="btn btn-primary btn-sm"
           asp-area="TeacherPortal" asp-controller="AcademicManagement" asp-action="CreateClass">
            <i class="bi bi-plus-lg me-1"></i>Add class
        </a>
    </div>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mb-3" role="alert">@message</div>
}

<div class="portal-card">
    <form method="get" class="row g-2 align-items-end mb-3"
          asp-area="TeacherPortal" asp-controller="AcademicManagement" asp-action="Classes">
        <div class="col-md-6">
            <label class="form-label" for="search">Search</label>
            <input type="search" class="form-control" id="search" name="search" value="@search"
                   placeholder="Name, code, program, section" />
        </div>
        <div class="col-md-3">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="showInactive" value="true" id="showInactive"
                       @(showInactive ? "checked" : "") />
                <label class="form-check-label" for="showInactive">Show inactive</label>
            </div>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Class name</th>
                    <th>Program</th>
                    <th>Semester</th>
                    <th>Year</th>
                    <th>Section</th>
                    <th>Shift</th>
                    <th>Room</th>
                    <th>Capacity</th>
                    <th>Active</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="11" class="text-center text-muted py-4">No classes found.</td></tr>
            }
            @foreach (var row in Model)
            {
                <tr>
                    <td class="fw-semibold">@row.ClassCode</td>
                    <td>@row.ClassName</td>
                    <td>@row.ProgramName</td>
                    <td>@row.Semester @row.SemesterNo</td>
                    <td>@row.AcademicYear</td>
                    <td>@(row.Section ?? "—")</td>
                    <td>@(row.Shift ?? "—")</td>
                    <td>@(row.RoomNo ?? "—")</td>
                    <td>@row.MaxStrength</td>
                    <td>@(row.IsActive ? "Yes" : "No")</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-sm btn-outline-primary"
                           asp-area="TeacherPortal" asp-controller="AcademicManagement" asp-action="EditClass"
                           asp-route-id="@row.Uid">Edit</a>
                        @if (row.IsActive)
                        {
                            <form method="post"
                                  asp-area="TeacherPortal" asp-controller="AcademicManagement" asp-action="DeleteClass"
                                  asp-route-id="@row.Uid" class="d-inline"
                                  onsubmit="return confirm('Deactivate this class?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Deactivate</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
