@using System.Globalization
@{
    var username = User.Identity?.Name ?? "Teacher";
    var employeeId = User.FindFirst("EmployeeId")?.Value;
    var loginAtDisplay = "—";

    if (DateTime.TryParse(
            User.FindFirst("LoginAt")?.Value,
            CultureInfo.InvariantCulture,
            DateTimeStyles.RoundtripKind,
            out var loginAt))
    {
        loginAtDisplay = loginAt.ToLocalTime().ToString("dd MMM yyyy HH:mm");
    }
}

<div class="portal-subheader">
    <div class="container-fluid px-3 px-lg-4 d-flex align-items-center gap-2 flex-nowrap">
        <p class="portal-login-inline mb-0 text-truncate">
            <span class="fw-semibold">@username</span>
            @if (!string.IsNullOrWhiteSpace(employeeId))
            {
                <span class="portal-login-sep">·</span>
                <span>Employee ID: @employeeId</span>
            }
            <span class="portal-login-sep">·</span>
            <span><i class="bi bi-clock me-1"></i>Logged in at @loginAtDisplay</span>
        </p>
        <form asp-area="TeacherPortal" asp-controller="Login" asp-action="Logout" method="post" class="portal-logout-form ms-auto flex-shrink-0">
            @Html.AntiForgeryToken()
            <button class="btn btn-sm btn-outline-primary portal-logout-btn" type="submit">
                <i class="bi bi-box-arrow-right me-1"></i>Logout
            </button>
        </form>
    </div>
</div>
