@using VEMS.Areas.TeacherPortal.Services
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var activeModuleKey = TeacherNavCatalog.ResolveModuleKey(currentController, currentAction);
}

<nav class="portal-module-nav" aria-label="Main modules">
    @foreach (var module in TeacherNavCatalog.TopBarModules)
    {
        var isActive = string.Equals(module.Key, activeModuleKey, StringComparison.OrdinalIgnoreCase);
        var firstLink = module.Links[0];
        <a class="portal-module-link @(isActive ? "active" : "")"
           asp-area="TeacherPortal"
           asp-controller="@firstLink.Controller"
           asp-action="@firstLink.Action"
           title="@module.Label">
            <i class="bi @module.IconClass"></i>
            <span>@module.Label</span>
        </a>
    }
</nav>
