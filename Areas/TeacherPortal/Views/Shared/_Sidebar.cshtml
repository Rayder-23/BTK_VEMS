@using VEMS.Areas.TeacherPortal.Services
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var activeModule = TeacherNavCatalog.GetModuleForRoute(currentController, currentAction);
    var moduleEntryLink = TeacherNavCatalog.GetModuleEntryLink(activeModule);
    var moduleLinks = activeModule.Links;
}

<div class="fee-erp-sidebar-inner d-flex flex-column h-100 teacher-portal-sidebar-inner">
    <div class="fee-erp-sidebar-brand px-3 py-4 border-bottom border-light border-opacity-10">
        <a asp-area="TeacherPortal"
           asp-controller="@moduleEntryLink.Controller"
           asp-action="@moduleEntryLink.Action"
           class="text-decoration-none text-white d-flex align-items-center gap-3">
            <span class="fee-erp-sidebar-logo rounded-3 d-inline-flex align-items-center justify-content-center">
                <i class="bi @activeModule.IconClass"></i>
            </span>
            <div class="fee-erp-sidebar-brand-text">
                <span class="d-block fw-bold small text-uppercase tracking-wide opacity-75">VEMS LMS</span>
                <span class="d-block fw-semibold">@activeModule.Label</span>
            </div>
        </a>
    </div>

    <nav class="fee-erp-nav flex-grow-1 overflow-auto py-3 px-2" aria-label="@activeModule.Label navigation">
        @if (moduleLinks.Count > 0)
        {
            <p class="teacher-portal-nav-heading px-2 mb-2 text-uppercase">@activeModule.Label</p>
            <ul class="nav flex-column fee-erp-nav-list teacher-portal-module-nav mb-0">
                @foreach (var link in moduleLinks)
                {
                    var isActive = TeacherNavCatalog.IsLinkActive(link, currentController, currentAction);
                    <li class="nav-item">
                        <a class="fee-erp-nav-link @(isActive ? "active" : "") portal-sidebar-link"
                           asp-area="TeacherPortal"
                           asp-controller="@link.Controller"
                           asp-action="@link.Action">
                            <i class="bi @link.IconClass"></i>
                            <span class="fee-erp-nav-label">@link.Label</span>
                        </a>
                    </li>
                }
            </ul>
        }

        <ul class="nav flex-column fee-erp-nav-list teacher-portal-main-nav @(moduleLinks.Count > 0 ? "mt-3" : "")">
            @foreach (var link in TeacherNavCatalog.PermanentSidebarLinks)
            {
                var isActive = TeacherNavCatalog.IsPermanentSidebarLinkActive(link, currentController, currentAction);
                <li class="nav-item">
                    <a class="fee-erp-nav-link @(isActive ? "active" : "") portal-sidebar-link"
                       asp-area="TeacherPortal"
                       asp-controller="@link.Controller"
                       asp-action="@link.Action">
                        <i class="bi @link.IconClass"></i>
                        <span class="fee-erp-nav-label">@link.Label</span>
                    </a>
                </li>
            }
        </ul>
    </nav>

    <div class="fee-erp-sidebar-foot p-3 mt-auto border-top border-light border-opacity-10">
        <div class="small text-white-50 px-1 teacher-portal-sidebar-hint">
            <i class="bi bi-info-circle me-1 opacity-75"></i>
            Use the top bar to switch modules. Dashboard and profile are always available below.
        </div>
    </div>
</div>
