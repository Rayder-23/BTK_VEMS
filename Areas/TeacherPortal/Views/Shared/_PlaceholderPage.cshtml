@{
    var pageTitle = ViewData["Title"]?.ToString() ?? "Page";
    var pageDescription = ViewData["Description"]?.ToString() ?? "This section is being prepared and will be available soon.";
}

<div class="portal-card">
    <div class="d-flex align-items-start gap-3">
        <span class="metric-icon flex-shrink-0"><i class="bi bi-hourglass-split"></i></span>
        <div>
            <h1 class="h4 fw-bold mb-2">@pageTitle</h1>
            <p class="text-muted mb-0">@pageDescription</p>
        </div>
    </div>
</div>
