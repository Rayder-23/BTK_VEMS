@{
    ViewData["Title"] = "Teacher Dashboard";
}

<div class="portal-card dashboard-metrics-compact mb-3">
    <div class="dashboard-metrics-grid">
        <div class="dashboard-metric">
            <i class="bi bi-easel dashboard-metric-icon"></i>
            <div class="dashboard-metric-body">
                <span class="dashboard-metric-label">Active Classes</span>
                <span class="dashboard-metric-value">5</span>
            </div>
        </div>
        <div class="dashboard-metric">
            <i class="bi bi-people dashboard-metric-icon"></i>
            <div class="dashboard-metric-body">
                <span class="dashboard-metric-label">Students</span>
                <span class="dashboard-metric-value">148</span>
            </div>
        </div>
        <div class="dashboard-metric">
            <i class="bi bi-calendar-check dashboard-metric-icon"></i>
            <div class="dashboard-metric-body">
                <span class="dashboard-metric-label">Attendance Due</span>
                <span class="dashboard-metric-value">3</span>
            </div>
        </div>
        <div class="dashboard-metric">
            <i class="bi bi-clipboard-data dashboard-metric-icon"></i>
            <div class="dashboard-metric-body">
                <span class="dashboard-metric-label">Results Pending</span>
                <span class="dashboard-metric-value">12</span>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-8">
        <div class="portal-card h-100">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h2 class="h5 fw-bold mb-1">Today&apos;s Teaching Schedule</h2>
                    <p class="text-muted mb-0">Classes and academic tasks planned for today.</p>
                </div>
                <i class="bi bi-clock-history fs-4 text-primary"></i>
            </div>
            <div class="list-group list-group-flush">
                <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                    <span>Web Development - Semester 4</span>
                    <span class="badge text-bg-primary rounded-pill">10:00 AM</span>
                </div>
                <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                    <span>Database Systems - Semester 3</span>
                    <span class="badge text-bg-primary rounded-pill">12:00 PM</span>
                </div>
                <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                    <span>Project Review Meeting</span>
                    <span class="badge text-bg-primary rounded-pill">03:30 PM</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="portal-card h-100">
            <h2 class="h5 fw-bold mb-3">Quick Actions</h2>
            <div class="d-grid gap-2">
                <a class="btn btn-outline-primary" asp-area="TeacherPortal" asp-controller="Attendance" asp-action="Index">
                    <i class="bi bi-calendar-plus me-2"></i>Mark Attendance
                </a>
                <a class="btn btn-outline-primary" asp-area="TeacherPortal" asp-controller="Results" asp-action="Index">
                    <i class="bi bi-upload me-2"></i>Upload Results
                </a>
                <a class="btn btn-outline-primary" asp-area="TeacherPortal" asp-controller="Classes" asp-action="Index">
                    <i class="bi bi-megaphone me-2"></i>My Classes
                </a>
            </div>
        </div>
    </div>
</div>
