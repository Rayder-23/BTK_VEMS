@{
    ViewData["Title"] = "Change Theme";
}

<div class="portal-card">
    <h1 class="h5 fw-bold mb-1">Change theme</h1>
    <p class="text-muted mb-4">Choose how the student portal looks on this device. Your preference is saved in your browser.</p>

    <div class="d-flex flex-column gap-2 student-theme-options" style="max-width: 320px;">
        <label class="student-theme-option">
            <input type="radio" name="studentTheme" value="default" />
            <span class="student-theme-option-body">
                <i class="bi bi-sun"></i>
                <span>
                    <span class="fw-semibold d-block">Default</span>
                    <small class="text-muted">Light workspace with blue accents</small>
                </span>
            </span>
        </label>
        <label class="student-theme-option">
            <input type="radio" name="studentTheme" value="dark" />
            <span class="student-theme-option-body">
                <i class="bi bi-moon-stars"></i>
                <span>
                    <span class="fw-semibold d-block">Dark</span>
                    <small class="text-muted">Reduced glare for low-light use</small>
                </span>
            </span>
        </label>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var key = 'vems-student-theme';
            var options = document.querySelectorAll('input[name="studentTheme"]');
            var saved = localStorage.getItem(key) || 'default';

            options.forEach(function (input) {
                input.checked = input.value === saved;
                input.addEventListener('change', function () {
                    if (!input.checked) return;
                    localStorage.setItem(key, input.value);
                    document.body.dataset.studentTheme = input.value === 'default' ? '' : input.value;
                });
            });
        })();
    </script>
}
