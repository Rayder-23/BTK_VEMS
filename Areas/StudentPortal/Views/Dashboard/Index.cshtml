@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="portal-card dashboard-metrics-compact mb-3">
    <div class="dashboard-metrics-grid">
        <div class="dashboard-metric">
            <i class="bi bi-book dashboard-metric-icon"></i>
            <div class="dashboard-metric-body">
                <span class="dashboard-metric-label">Enrolled Courses</span>
                <span class="dashboard-metric-value">6</span>
            </div>
        </div>
        <div class="dashboard-metric">
            <i class="bi bi-calendar-check dashboard-metric-icon"></i>
            <div class="dashboard-metric-body">
                <span class="dashboard-metric-label">Attendance</span>
                <span class="dashboard-metric-value">92%</span>
            </div>
        </div>
        <div class="dashboard-metric">
            <i class="bi bi-award dashboard-metric-icon"></i>
            <div class="dashboard-metric-body">
                <span class="dashboard-metric-label">Current GPA</span>
                <span class="dashboard-metric-value">3.7</span>
            </div>
        </div>
        <div class="dashboard-metric">
            <i class="bi bi-envelope dashboard-metric-icon"></i>
            <div class="dashboard-metric-body">
                <span class="dashboard-metric-label">Messages</span>
                <span class="dashboard-metric-value">4</span>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-8">
        <div class="portal-card h-100">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h2 class="h5 fw-bold mb-1">Upcoming Classes</h2>
                    <p class="text-muted mb-0">Your next scheduled academic activities.</p>
                </div>
                <i class="bi bi-calendar3 fs-4 text-primary"></i>
            </div>
            <div class="list-group list-group-flush">
                <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                    <span>Mathematics - Linear Algebra</span>
                    <span class="badge text-bg-primary rounded-pill">09:00 AM</span>
                </div>
                <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                    <span>Computer Science - Web Development</span>
                    <span class="badge text-bg-primary rounded-pill">11:30 AM</span>
                </div>
                <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                    <span>English Communication Lab</span>
                    <span class="badge text-bg-primary rounded-pill">02:00 PM</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="portal-card h-100">
            <h2 class="h5 fw-bold mb-3">Quick Actions</h2>
            <div class="d-grid gap-2">
                <a class="btn btn-outline-primary" href="#"><i class="bi bi-download me-2"></i>Download Result</a>
                <a class="btn btn-outline-primary" href="#"><i class="bi bi-check2-square me-2"></i>View Attendance</a>
                <a class="btn btn-outline-primary" href="#"><i class="bi bi-chat-left-text me-2"></i>Contact Teacher</a>
            </div>
        </div>
    </div>
</div>
