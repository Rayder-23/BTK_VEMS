<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/portals/student-portal.css" asp-append-version="true" />
</head>
@{
    var displayName = User.Identity?.Name ?? "Student";
    var avatarLetter = displayName.Length > 0 ? displayName[0].ToString().ToUpperInvariant() : "S";
}
<body class="portal-shell student-portal">
    <header class="portal-header">
        <nav class="navbar navbar-expand-lg portal-navbar portal-navbar-primary">
            <div class="container-fluid px-3 px-lg-4 d-flex align-items-center gap-2">
                <button class="btn btn-outline-light btn-sm d-lg-none flex-shrink-0 portal-menu-btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#portalSidebar" aria-controls="portalSidebar">
                    <i class="bi bi-list"></i>
                </button>
                <partial name="_TopNavbar" />
                <div class="portal-navbar-user ms-auto flex-shrink-0">
                    <span class="portal-user-avatar portal-user-avatar-sm" title="@displayName">@avatarLetter</span>
                </div>
            </div>
        </nav>
        <partial name="_SubNavbar" />
    </header>

    <div class="portal-body">
        <aside class="portal-sidebar d-none d-lg-flex">
            <partial name="_Sidebar" />
        </aside>

        <div class="offcanvas offcanvas-start portal-offcanvas" tabindex="-1" id="portalSidebar" aria-labelledby="portalSidebarLabel">
            <div class="offcanvas-header border-bottom">
                <h5 class="offcanvas-title" id="portalSidebarLabel">Student Portal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body p-0">
                <partial name="_Sidebar" />
            </div>
        </div>

        <div class="portal-main">
            <main class="portal-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
