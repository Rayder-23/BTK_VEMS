@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}

<div class="sidebar-inner">
    <a class="portal-brand" asp-area="StudentPortal" asp-controller="Dashboard" asp-action="Index">
        <span class="brand-icon"><i class="bi bi-mortarboard-fill"></i></span>
        <span>
            <span class="brand-title">Student Portal</span>
            <small>Learning workspace</small>
        </span>
    </a>

    <nav class="portal-menu" aria-label="Student portal navigation">
        <a class="portal-menu-link @(currentController == "Dashboard" ? "active" : "")"
           asp-area="StudentPortal" asp-controller="Dashboard" asp-action="Index">
            <i class="bi bi-speedometer2"></i>
            <span>Dashboard</span>
        </a>
        <a class="portal-menu-link @(currentController == "Profile" ? "active" : "")"
           asp-area="StudentPortal" asp-controller="Profile" asp-action="Index">
            <i class="bi bi-person-circle"></i>
            <span>Profile</span>
        </a>
        <a class="portal-menu-link" href="#">
            <i class="bi bi-journal-bookmark"></i>
            <span>Courses</span>
        </a>
        <a class="portal-menu-link" href="#">
            <i class="bi bi-calendar-check"></i>
            <span>Attendance</span>
        </a>
        <a class="portal-menu-link" href="#">
            <i class="bi bi-clipboard-data"></i>
            <span>Results</span>
        </a>
        <a class="portal-menu-link" href="#">
            <i class="bi bi-gear"></i>
            <span>Settings</span>
        </a>
    </nav>

    <div class="sidebar-card">
        <p class="mb-1 fw-semibold">Need help?</p>
        <small>Contact academic support for portal assistance.</small>
    </div>
</div>
