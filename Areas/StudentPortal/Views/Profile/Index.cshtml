@model StudentProfilePageViewModel
@{
    ViewData["Title"] = "My Profile";
    var profile = Model.Profile;
}

<section class="module-page-header accent-blue mb-4">
    <div class="d-flex align-items-center gap-3">
        <span class="module-page-icon"><i class="bi bi-person-circle"></i></span>
        <div>
            <h1 class="h3 fw-bold mb-1">@profile.FullName</h1>
            <p class="text-muted mb-0">@profile.RegistrationNo@(string.IsNullOrEmpty(profile.RollNo) ? "" : $" · Roll {profile.RollNo}")</p>
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="portal-card h-100">
            <h2 class="h5 fw-bold mb-3">Personal information</h2>
            <dl class="row mb-0 profile-dl">
                <dt class="col-sm-4">Father's name</dt>
                <dd class="col-sm-8">@profile.FatherName</dd>
                <dt class="col-sm-4">Date of birth</dt>
                <dd class="col-sm-8">@profile.DateOfBirth.ToString("dd MMM yyyy")</dd>
                <dt class="col-sm-4">Gender</dt>
                <dd class="col-sm-8">@profile.GenderDisplay</dd>
                <dt class="col-sm-4">Nationality</dt>
                <dd class="col-sm-8">@(profile.Nationality ?? "—")</dd>
                <dt class="col-sm-4">CNIC</dt>
                <dd class="col-sm-8">@(profile.NicNo ?? "—")</dd>
                <dt class="col-sm-4">B-Form</dt>
                <dd class="col-sm-8">@(profile.BformNo ?? "—")</dd>
                <dt class="col-sm-4">Status</dt>
                <dd class="col-sm-8">@(profile.IsActive ? "Active" : "Inactive")</dd>
                @if (!string.IsNullOrWhiteSpace(profile.StatusRemark))
                {
                    <dt class="col-sm-4">Remark</dt>
                    <dd class="col-sm-8">@profile.StatusRemark</dd>
                }
            </dl>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="portal-card h-100">
            <h2 class="h5 fw-bold mb-3">Academic information</h2>
            <dl class="row mb-0 profile-dl">
                <dt class="col-sm-4">Program</dt>
                <dd class="col-sm-8">@(profile.ProgramName ?? "—")</dd>
                <dt class="col-sm-4">Admission year</dt>
                <dd class="col-sm-8">@profile.AdmissionYear</dd>
                <dt class="col-sm-4">Admission date</dt>
                <dd class="col-sm-8">@profile.AdmissionDate.ToString("dd MMM yyyy")</dd>
                <dt class="col-sm-4">Registration</dt>
                <dd class="col-sm-8">@profile.RegistrationNo</dd>
                <dt class="col-sm-4">Roll number</dt>
                <dd class="col-sm-8">@(profile.RollNo ?? "—")</dd>
            </dl>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="portal-card h-100">
            <h2 class="h5 fw-bold mb-3">Address</h2>
            <dl class="row mb-0 profile-dl">
                <dt class="col-sm-4">Line 1</dt>
                <dd class="col-sm-8">@profile.AddressLine1</dd>
                @if (!string.IsNullOrWhiteSpace(profile.AddressLine2))
                {
                    <dt class="col-sm-4">Line 2</dt>
                    <dd class="col-sm-8">@profile.AddressLine2</dd>
                }
                <dt class="col-sm-4">City</dt>
                <dd class="col-sm-8">@(profile.CityName ?? "—")</dd>
                <dt class="col-sm-4">Province</dt>
                <dd class="col-sm-8">@(profile.ProvinceName ?? "—")</dd>
                <dt class="col-sm-4">Country</dt>
                <dd class="col-sm-8">@(profile.CountryName ?? "—")</dd>
                <dt class="col-sm-4">Postal code</dt>
                <dd class="col-sm-8">@(profile.PostalCode ?? "—")</dd>
            </dl>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="portal-card h-100">
            <h2 class="h5 fw-bold mb-3">Portal account</h2>
            <dl class="row mb-0 profile-dl">
                <dt class="col-sm-4">Username</dt>
                <dd class="col-sm-8">@(profile.PortalUsername ?? "—")</dd>
                <dt class="col-sm-4">Email</dt>
                <dd class="col-sm-8">@(profile.PortalEmail ?? "—")</dd>
                <dt class="col-sm-4">Login status</dt>
                <dd class="col-sm-8">@(profile.PortalStatus ?? "—")</dd>
                <dt class="col-sm-4">Last login</dt>
                <dd class="col-sm-8">@(profile.LastLoginAt?.ToString("dd MMM yyyy HH:mm") ?? "—")</dd>
            </dl>
        </div>
    </div>

</div>
