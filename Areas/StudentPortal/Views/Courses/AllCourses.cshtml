@model StudentAllCoursesPageModel
@{
    ViewData["Title"] = "All Courses";
    var primaryEnrollment = Model.Enrollments.FirstOrDefault();
}

<div class="portal-card challan-summary-compact mb-3">
    <div class="challan-summary-head">
        <div class="challan-summary-title">
            <span class="challan-summary-no">All Courses</span>
            @if (!string.IsNullOrWhiteSpace(Model.ProgramName))
            {
                <span class="student-program-title d-block mt-1">@Model.ProgramName</span>
                <span class="challan-summary-meta">
                    @if (!string.IsNullOrWhiteSpace(Model.ProgramCode))
                    {
                        <span>@Model.ProgramCode</span>
                        <span> · </span>
                    }
                    @if (primaryEnrollment is not null)
                    {
                        <span>Year @primaryEnrollment.AcademicYear · Semester @primaryEnrollment.GradeOrSemester</span>
                    }
                    else if (Model.AdmissionYear.HasValue)
                    {
                        <span>Admission @Model.AdmissionYear</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.RollNo))
                    {
                        <span> · Roll @Model.RollNo</span>
                    }
                </span>
            }
            else
            {
                <span class="challan-summary-meta d-block mt-1">No program assigned to your student record.</span>
            }
        </div>
        <span class="badge rounded-pill text-bg-light border challan-summary-status">
            @(Model.Courses.Count > 0 ? $"{Model.Courses.Count} course(s)" : "No courses")
        </span>
    </div>
</div>

<div class="portal-card">
    @if (string.IsNullOrWhiteSpace(Model.ProgramName) && Model.Enrollments.Count == 0)
    {
        <p class="text-muted mb-0">You do not have an active enrollment. Assigned courses will appear here once enrolled.</p>
    }
    else if (Model.Courses.Count == 0)
    {
        <p class="text-muted mb-0">No courses are assigned for your current enrollment yet.</p>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h6 fw-bold mb-0">Assigned courses</h2>
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0 student-courses-table">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Course</th>
                        <th>Semester</th>
                        <th>Credits</th>
                        <th class="text-end">Details</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var course in Model.Courses)
                {
                    var collapseId = $"course-detail-{course.CourseId}";
                    <tr>
                        <td class="fw-semibold">@(string.IsNullOrEmpty(course.CourseCode) ? "—" : course.CourseCode)</td>
                        <td>@course.CourseName</td>
                        <td>@course.GradeOrSemester</td>
                        <td>@(course.CreditHours?.ToString() ?? "—")</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#@collapseId"
                                    aria-expanded="false"
                                    aria-controls="@collapseId">
                                View
                            </button>
                        </td>
                    </tr>
                    <tr class="collapse-row">
                        <td colspan="5" class="p-0 border-0">
                            <div class="collapse" id="@collapseId">
                                <div class="border-top bg-light bg-opacity-50 p-3 mx-0 mb-2 rounded-bottom">
                                    <div class="row g-3 small">
                                        <div class="col-md-4">
                                            <span class="text-muted d-block">Program</span>
                                            <span>@course.ProgramName</span>
                                        </div>
                                        <div class="col-md-4">
                                            <span class="text-muted d-block">Academic year</span>
                                            <span>@course.AcademicYear</span>
                                        </div>
                                        <div class="col-md-4">
                                            <span class="text-muted d-block">Enrollment semester</span>
                                            <span>@course.GradeOrSemester</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
