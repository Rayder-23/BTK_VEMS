@{
    ViewData["Title"] = "Student Portal";
}

<div class="container py-5">
    <header class="border-bottom pb-4 mb-4">
        <p class="text-primary fw-semibold small text-uppercase mb-2">Student</p>
        <h1 class="display-6 fw-bold">Welcome to the Student Portal</h1>
        <p class="lead text-muted mb-0">
            Your courses, schedules, grades, and announcements will appear here as modules are connected to this area.
        </p>
    </header>
    <div class="row g-4">
        <div class="col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h2 class="h5 fw-semibold mb-2"><i class="bi bi-journal-bookmark-fill text-primary me-2"></i>My courses</h2>
                    <p class="small text-muted mb-0">Access materials, assignments, and deadlines.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h2 class="h5 fw-semibold mb-2"><i class="bi bi-calendar-event-fill text-primary me-2"></i>Schedule</h2>
                    <p class="small text-muted mb-0">View live sessions and campus events.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h2 class="h5 fw-semibold mb-2"><i class="bi bi-inbox-fill text-primary me-2"></i>Messages</h2>
                    <p class="small text-muted mb-0">Contact faculty and advising in one place.</p>
                </div>
            </div>
        </div>
    </div>
</div>
