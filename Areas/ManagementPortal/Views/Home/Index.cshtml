@{
    ViewData["Title"] = "Management Portal";
}

<div class="container py-5">
    <header class="border-bottom pb-4 mb-4">
        <p class="text-primary fw-semibold small text-uppercase mb-2">Administration</p>
        <h1 class="display-6 fw-bold">Welcome to the Management Portal</h1>
        <p class="lead text-muted mb-0">
            Oversee enrolment, programs, compliance, analytics, and institutional settings from this dashboard hub.
        </p>
    </header>
    <div class="row g-4">
        <div class="col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h2 class="h5 fw-semibold mb-2"><i class="bi bi-building-check text-primary me-2"></i>Programs</h2>
                    <p class="small text-muted mb-0">Academic structure, terms, and catalogs.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h2 class="h5 fw-semibold mb-2"><i class="bi bi-graph-up-arrow text-primary me-2"></i>Analytics</h2>
                    <p class="small text-muted mb-0">Retention, outcomes, and operational KPIs.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h2 class="h5 fw-semibold mb-2"><i class="bi bi-shield-lock-fill text-primary me-2"></i>Governance</h2>
                    <p class="small text-muted mb-0">Policies, roles, and audit-ready reporting.</p>
                </div>
            </div>
        </div>
    </div>
</div>
